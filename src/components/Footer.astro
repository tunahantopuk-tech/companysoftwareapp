---
const year = new Date().getFullYear();

const pages = [
  { label: 'Ana Sayfa',    href: '/' },
  { label: 'Uygulamalar', href: '/#uygulamalar' },
  { label: 'Oyunlar',     href: '/#oyunlar' },
  { label: 'Hizmetler',  href: '/hizmetler' },
  { label: 'İletişim',   href: '/iletisim' },
];
---

<footer class="footer">
  <div class="footer-inner">

    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo-link">
        <img src="/images/logo-company.png" alt="Company Software App" class="footer-logo-img" />
        <span class="footer-logo-text">Company <strong>Software App</strong></span>
      </a>
      <p class="footer-tagline">
        iOS, Android ve web için yalın,<br />güçlü dijital deneyimler.
      </p>
    </div>

    <!-- Navigation -->
    <div class="footer-col">
      <p class="footer-col-title">Sayfalar</p>
      <ul class="footer-nav-list">
        {pages.map(p => (
          <li><a href={p.href} class="footer-nav-link">{p.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Social & Legal -->
    <div class="footer-col">
      <p class="footer-col-title">Takip Et</p>
      <div class="footer-social-row">
        <a href="#" class="footer-social-btn" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a href="#" class="footer-social-btn" aria-label="X (Twitter)" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>
      <div class="footer-legal-links">
        <a href="/gizlilik-politikasi" class="footer-legal-link">Gizlilik</a>
        <a href="/kullanim-kosullari"  class="footer-legal-link">Kullanım Koşulları</a>
      </div>
    </div>

  </div>

  <hr class="footer-divider" />

  <p class="footer-copy">© {year} Company Software App. Tüm hakları saklıdır.</p>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-faint);
    padding: 56px 24px 32px;
    margin-top: 0;
  }
  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 680px) {
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  }

  /* Brand column */
  .footer-logo-link {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; margin-bottom: 16px;
  }
  .footer-logo-img {
    height: 36px; width: auto; object-fit: contain;
  }
  .footer-logo-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; color: var(--color-text);
  }
  .footer-logo-text strong { font-weight: 700; }
  .footer-tagline {
    font-size: 13px; color: var(--color-subtle); line-height: 1.65;
  }

  /* Nav & social columns */
  .footer-col-title {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--color-subtle); margin-bottom: 16px;
  }
  .footer-nav-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .footer-nav-link {
    font-size: 14px; color: var(--color-muted);
    text-decoration: none; transition: color 0.15s ease;
  }
  .footer-nav-link:hover { color: var(--color-text); }

  /* Social */
  .footer-social-row { display: flex; gap: 10px; margin-bottom: 24px; }
  .footer-social-btn {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    background: var(--hover-overlay);
    color: var(--color-muted); text-decoration: none;
    border: 1px solid var(--border-faint);
    transition: color 0.15s ease, background 0.15s ease;
  }
  .footer-social-btn:hover { color: var(--color-text); background: rgba(160,0,32,0.10); border-color: rgba(160,0,32,0.3); }

  /* Legal */
  .footer-legal-links { display: flex; flex-direction: column; gap: 8px; }
  .footer-legal-link {
    font-size: 13px; color: var(--color-subtle); text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-legal-link:hover { color: var(--color-muted); }

  /* Bottom */
  .footer-divider {
    height: 1px; border: none; background: var(--border-faint);
    margin: 40px auto 0; max-width: 1080px;
  }
  .footer-copy {
    max-width: 1080px; margin: 20px auto 0;
    font-size: 12px; color: var(--color-subtle); text-align: center;
  }
</style>
