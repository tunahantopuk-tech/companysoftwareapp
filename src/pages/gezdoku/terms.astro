---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const accent = '#22D3EE';
const lastUpdated = '31 Mayıs 2026';
---

<Layout
  title="GezDoku — Kullanım Koşulları"
  description="GezDoku uygulaması kullanım koşulları."
>
  <Header />

  <main style="padding-top: 64px;">

    <!-- Hero -->
    <section style="padding: 64px 24px 56px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.05);">
      <div style="max-width: 640px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 16px;">
        <a href="/gezdoku" style="display: flex; align-items: center; gap: 10px; text-decoration: none; margin-bottom: 4px;">
          <img src="/images/logo-gezdoku.png" alt="GezDoku" style="width: 44px; height: 44px; border-radius: 10px;" />
          <span class="font-heading" style="font-size: 1.125rem; font-weight: 600; color: #fff;">GezDoku</span>
        </a>
        <h1 class="font-heading" style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: #fff; line-height: 1.2;">
          Kullanım Koşulları
        </h1>
        <p style="font-size: 0.875rem; color: #475569;">
          Son güncelleme: <span style={`color: ${accent};`}>{lastUpdated}</span>
        </p>
        <p style="color: #94A3B8; font-size: 0.95rem; line-height: 1.7; max-width: 520px;">
          Bu uygulamayı indirerek veya kullanarak aşağıdaki koşulları kabul etmiş sayılırsınız.
        </p>
      </div>
    </section>

    <!-- Maddeler -->
    <section style="max-width: 720px; margin: 0 auto; padding: 56px 24px 80px;">
      <div style="display: flex; flex-direction: column; gap: 0;">

        {/* 1. Kabul */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>1</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 10px;">Kabul</h2>
            <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75;">
              Bu uygulamayı indirerek veya kullanarak aşağıdaki koşulları kabul etmiş sayılırsınız. Kabul etmiyorsanız uygulamayı kullanmayınız.
            </p>
          </div>
        </div>

        {/* 2. Lisans */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>2</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 12px;">Lisans</h2>
            <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75; margin-bottom: 14px;">
              GezDoku size kişisel, devredilemez, münhasır olmayan bir kullanım lisansı verir.
            </p>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
              <div style="background: rgba(34,211,238,0.06); border: 1px solid rgba(34,211,238,0.2); border-radius: 12px; padding: 14px;">
                <p style={`font-size: 0.8rem; font-weight: 700; color: ${accent}; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em;`}>İzin Verilenler</p>
                {['Kişisel amaçlarla kullanmak', 'Kendi cihazlarına indirmek'].map(item => (
                  <div style="display: flex; gap: 8px; align-items: flex-start; margin-bottom: 6px;">
                    <span style={`color: ${accent}; font-size: 12px; flex-shrink: 0; margin-top: 2px;`}>✓</span>
                    <p style="font-size: 0.8rem; color: #94A3B8; line-height: 1.5;">{item}</p>
                  </div>
                ))}
              </div>
              <div style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.2); border-radius: 12px; padding: 14px;">
                <p style="font-size: 0.8rem; font-weight: 700; color: #F87171; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em;">Yasak Olanlar</p>
                {['Kopyalamak, değiştirmek veya dağıtmak', 'Tersine mühendislik yapmak', 'Ticari amaçla kullanmak', 'Kiralamak veya satmak'].map(item => (
                  <div style="display: flex; gap: 8px; align-items: flex-start; margin-bottom: 6px;">
                    <span style="color: #F87171; font-size: 12px; flex-shrink: 0; margin-top: 2px;">✕</span>
                    <p style="font-size: 0.8rem; color: #94A3B8; line-height: 1.5;">{item}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        {/* 3. Uygulama İçi Satın Almalar */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>3</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 12px;">Uygulama İçi Satın Almalar ve Reklamlar</h2>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              {[
                'Uygulama, ödüllü reklamlar aracılığıyla oyun içi içerik (kargo, güç) sunmaktadır.',
                'Reklam izleme zorunlu değildir; isteğe bağlıdır.',
                'Uygulama içi satın almalar yapılmışsa, Apple\'ın iade politikası geçerlidir.',
                'Reklam karşılığı kazanılan oyun içi ödüller gerçek para değeri taşımaz ve nakde çevrilemez.',
              ].map(item => (
                <div style="display: flex; gap: 10px; align-items: flex-start;">
                  <div style={`width: 6px; height: 6px; border-radius: 50%; background: ${accent}; flex-shrink: 0; margin-top: 7px;`}></div>
                  <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75;">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* 4. Kullanıcı Davranışı */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>4</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 12px;">Kullanıcı Davranışı</h2>
            <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75; margin-bottom: 12px;">Aşağıdaki davranışlar yasaktır:</p>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              {[
                'Oyun içi verileri hile yoluyla değiştirmek',
                'Lider tablolarını manipüle etmek',
                'Uygulamayı başkalarına zarar verecek şekilde kullanmak',
                'Uygulamanın altyapısına yetkisiz erişim sağlamaya çalışmak',
              ].map(item => (
                <div style="display: flex; gap: 10px; align-items: flex-start;">
                  <div style="width: 6px; height: 6px; border-radius: 50%; background: #F87171; flex-shrink: 0; margin-top: 7px;"></div>
                  <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75;">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* 5. Fikri Mülkiyet */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>5</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 10px;">Fikri Mülkiyet</h2>
            <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75;">
              Uygulamadaki tüm içerikler (tasarım, bulmacalar, görseller, ses efektleri, metin) GezDoku'ya aittir ve telif hukuku ile korunmaktadır. İzinsiz kullanılamaz.
            </p>
          </div>
        </div>

        {/* 6. Üçüncü Taraf Hizmetleri */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>6</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 10px;">Üçüncü Taraf Hizmetleri</h2>
            <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75; margin-bottom: 14px;">
              Uygulama; Unity Ads ve Apple Game Center gibi üçüncü taraf hizmetler içermektedir. Bu hizmetlerin kullanım koşulları kendi sağlayıcılarına aittir:
            </p>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              {[
                { label: 'Unity Kullanım Koşulları', href: 'https://unity.com/legal/terms-of-service' },
                { label: 'Apple Medya Hizmetleri Koşulları', href: 'https://www.apple.com/legal/internet-services/itunes/tr/terms.html' },
              ].map(link => (
                <a href={link.href} target="_blank" rel="noopener noreferrer" style={`display: inline-flex; align-items: center; gap: 6px; font-size: 0.875rem; color: ${accent}; text-decoration: none;`}>
                  <span>{link.label} ↗</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        {/* 7. Sorumluluk Reddi */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>7</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 12px;">Sorumluluk Reddi</h2>
            <div style="display: flex; flex-direction: column; gap: 8px;">
              {[
                'Uygulama "olduğu gibi" sunulmaktadır; kesintisiz veya hatasız çalışacağı garanti edilmez.',
                'Uygulama kullanımından doğabilecek doğrudan veya dolaylı zararlardan sorumlu değiliz.',
                'Bulmaca içerikleri eğlence amaçlıdır; herhangi bir konuda profesyonel tavsiye niteliği taşımaz.',
              ].map(item => (
                <div style="display: flex; gap: 10px; align-items: flex-start;">
                  <div style={`width: 6px; height: 6px; border-radius: 50%; background: ${accent}; flex-shrink: 0; margin-top: 7px;`}></div>
                  <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75;">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* 8. Fesih */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>8</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 10px;">Fesih</h2>
            <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75;">
              Bu koşulları ihlal etmeniz durumunda lisansınız otomatik olarak sona erer ve uygulamayı kullanma hakkınızı kaybedersiniz.
            </p>
          </div>
        </div>

        {/* 9. Değişiklikler */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>9</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 10px;">Değişiklikler</h2>
            <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75;">
              Kullanım koşullarını önceden bildirim yapmaksızın değiştirme hakkımız saklıdır. Güncel koşullar her zaman bu sayfada yayımlanır. Uygulamayı kullanmaya devam etmeniz değişiklikleri kabul ettiğiniz anlamına gelir.
            </p>
          </div>
        </div>

        {/* 10. Uygulanacak Hukuk */}
        <div style="display: flex; gap: 20px; padding: 32px 0; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>10</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 10px;">Uygulanacak Hukuk</h2>
            <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75;">
              Bu koşullar <strong style="color: #e2e8f0;">Türkiye Cumhuriyeti</strong> hukukuna tabidir. Anlaşmazlıklarda <strong style="color: #e2e8f0;">İstanbul</strong> mahkemeleri yetkilidir.
            </p>
          </div>
        </div>

        {/* 11. İletişim */}
        <div style="display: flex; gap: 20px; padding: 32px 0;">
          <div style={`width: 32px; height: 32px; border-radius: 8px; background: ${accent}18; border: 1px solid ${accent}35; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px;`}>
            <span style={`font-size: 0.75rem; font-weight: 700; color: ${accent}; font-family: sans-serif;`}>11</span>
          </div>
          <div style="flex: 1;">
            <h2 class="font-heading" style="font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 10px;">İletişim</h2>
            <p style="font-size: 0.9rem; color: #94A3B8; line-height: 1.75; margin-bottom: 8px;">Sorularınız için bizimle iletişime geçebilirsiniz:</p>
            <a href="mailto:support@iflimlik.com" style={`display: inline-block; font-size: 0.9rem; font-weight: 500; color: ${accent}; text-decoration: none;`}>
              support@iflimlik.com
            </a>
          </div>
        </div>

      </div>

      <!-- Geri dön -->
      <div style="margin-top: 48px; text-align: center;">
        <a href="/gezdoku" style="font-size: 0.875rem; color: #475569; text-decoration: none;">
          ← GezDoku'ya Dön
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
