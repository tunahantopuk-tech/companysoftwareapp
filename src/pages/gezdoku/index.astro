---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const accent = '#22D3EE';

const scrollFeatures = [
  {
    title: 'Üç Farklı Bulmaca',
    sub: 'Mahalle, İlçe ve Şehir Bulmacalarını Çöz, Rozet Kazan',
    description: 'Mahalle, ilçe ve şehir seviyelerinde bulmacaları çöz. Her tamamlanan bulmaca seni bir adım öne taşır ve özel rozetler kazandırır.',
  },
  {
    title: 'Pasaportunu Doldur',
    sub: 'Yeni Yerler Keşfet',
    description: "Her çözdüğün bulmaca pasaportunuza bir damga ekler. Türkiye'nin dört bir yanını keşfet, pasaportunuzu tüm damgalarla doldur.",
  },
  {
    title: 'Sonsuz Mod',
    sub: 'Sonsuz Mod ile İstediğin Bulmacayı Oyna',
    description: 'Sonsuz modda sınır yoktur. İstediğin bölgeyi seç, istediğin kadar oyna. Bulmaca çözme keyfi hiç bitmesin.',
  },
  {
    title: 'Kesintisiz Mod',
    sub: 'Gidebildiğin Yere Git',
    description: 'Kesintisiz modda ne kadar ileri gidebilirsin? Hatayla karşılaşmadan zincirleme bulmacaları çöz, rekorunu kır.',
  },
  {
    title: 'Game Center',
    sub: 'Yerel ve Global Yarış',
    description: 'Yakın çevrende ve tüm dünyada yarış. Yerel ve global liderlik tablolarında en üste çıkmak için mücadele et.',
  },
];
---

<Layout
  title="GezDoku | Company Software App"
  description="Mahalle, ilçe ve şehir bulmacalarını çöz, yeni yerler keşfet, rozetler kazan. Çok yakında."
  ogImage="/images/logo-gezdoku.png"
>
  <Header />

  <main style="padding-top: 56px;">

    <!-- ── Hero ──────────────────────────────────── -->
    <section class="hero-section">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-inner">
        <img
          src="/images/logo-gezdoku.png"
          alt="GezDoku"
          width="96" height="96"
          class="hero-logo"
        />
        <div>
          <h1 class="hero-title font-heading">GezDoku</h1>
          <p class="hero-desc">
            Mahalle, ilçe ve şehir bulmacalarını çöz. Türkiye'yi keşfet, pasaportunuzu doldur, liderlik tablolarında zirveye ulaş.
          </p>
        </div>
        <div class="badge-coming-soon">
          <span class="badge-dot"></span>
          <span class="badge-text">Yakında</span>
        </div>
        <div class="social-row">
          <a href="#" class="social-btn" aria-label="GezDoku Instagram" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="social-btn" aria-label="GezDoku X" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </section>

    <hr class="page-divider" />

    <!-- ── Scroll features ────────────────────────── -->
    <section style="max-width: 1152px; margin: 0 auto; padding: 32px 24px;">
      <div class="scroll-grid">

        <div>
          {scrollFeatures.map((f, i) => (
            <div class="scroll-feature" data-index={i} style="min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 64px 0; max-width: 420px;">
              <p class="feature-eyebrow">GezDoku</p>
              <h2 class="feature-heading font-heading">{f.title}</h2>
              <p class="feature-sub font-heading" style={`color: ${accent};`}>{f.sub}</p>
              <p class="feature-desc">{f.description}</p>
            </div>
          ))}
        </div>

        <!-- Sticky phone -->
        <div class="phone-sticky-col">
          <div style="display: flex; align-items: center; justify-content: center; height: 100%;">
            <div class="phone-frame">
              <div class="phone-island"></div>
              <div class="phone-screen">

                <!-- Ekran 0: Üç Farklı Bulmaca -->
                <div class="phone-shot active" data-shot="0">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #071a20 0%, #0a2535 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px;">
                      <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif; margin-bottom: 4px;">BULMACALAR</p>
                      <p style="color: #fff; font-size: 18px; font-weight: 700; font-family: sans-serif; margin-bottom: 16px;">Seviye Seç</p>
                      <div style="display: flex; flex-direction: column; gap: 10px;">
                        {[
                          { name: 'Mahalle', desc: '928 bulmaca', color: '#22D3EE', icon: '🏘️', badge: '12' },
                          { name: 'İlçe', desc: '973 bulmaca', color: '#06B6D4', icon: '🏙️', badge: '5' },
                          { name: 'Şehir', desc: '81 bulmaca', color: '#0891B2', icon: '🌆', badge: '2' },
                        ].map(lvl => (
                          <div style={`background: ${lvl.color}12; border: 1px solid ${lvl.color}30; border-radius: 16px; padding: 14px;`}>
                            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
                              <span style="font-size: 22px;">{lvl.icon}</span>
                              <div style="flex: 1;">
                                <p style="color: #fff; font-size: 14px; font-weight: 700; font-family: sans-serif;">{lvl.name}</p>
                                <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif;">{lvl.desc}</p>
                              </div>
                              <div style={`background: ${lvl.color}25; border: 1px solid ${lvl.color}50; border-radius: 20px; padding: 3px 10px;`}>
                                <p style={`color: ${lvl.color}; font-size: 11px; font-weight: 700; font-family: sans-serif;`}>{lvl.badge} rozet</p>
                              </div>
                            </div>
                            <div style="height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden;">
                              <div style={`height: 100%; width: ${lvl.badge === '12' ? '65%' : lvl.badge === '5' ? '30%' : '15%'}; background: ${lvl.color}; border-radius: 2px;`}></div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Ekran 1: Pasaportunu Doldur -->
                <div class="phone-shot" data-shot="1">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #050f1a 0%, #0a1f30 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px;">
                      <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif; margin-bottom: 4px;">PASAPORT</p>
                      <p style="color: #fff; font-size: 18px; font-weight: 700; font-family: sans-serif; margin-bottom: 14px;">Keşif Haritam</p>
                      <div style="background: linear-gradient(135deg, #0c4a6e, #164e63); border: 1px solid rgba(34,211,238,0.2); border-radius: 16px; padding: 14px; margin-bottom: 12px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                          <p style="color: #22D3EE; font-size: 11px; font-weight: 700; font-family: sans-serif; letter-spacing: 0.1em;">GEZDoku PASSport</p>
                          <span style="font-size: 20px;">🗺️</span>
                        </div>
                        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px;">
                          {[
                            {label:'İST',done:true},{label:'ANK',done:true},{label:'İZM',done:true},{label:'BUR',done:true},
                            {label:'ANT',done:true},{label:'KON',done:false},{label:'GAZ',done:false},{label:'ADN',done:false},
                          ].map(city => (
                            <div style={`aspect-ratio: 1; border-radius: 8px; display: flex; align-items: center; justify-content: center; ${city.done ? 'background: rgba(34,211,238,0.2); border: 1.5px solid rgba(34,211,238,0.5);' : 'background: rgba(255,255,255,0.04); border: 1px dashed rgba(255,255,255,0.12);'}`}>
                              <p style={`font-size: 9px; font-weight: 700; font-family: sans-serif; ${city.done ? 'color: #22D3EE;' : 'color: rgba(255,255,255,0.2);'}`}>{city.label}</p>
                            </div>
                          ))}
                        </div>
                      </div>
                      <div style="display: flex; justify-content: space-between;">
                        {[{v:'47',l:'Keşfedilen'},{v:'81',l:'Toplam Şehir'},{v:'58%',l:'Tamamlanan'}].map(s => (
                          <div style="text-align: center;">
                            <p style="color: #22D3EE; font-size: 20px; font-weight: 800; font-family: sans-serif; line-height: 1;">{s.v}</p>
                            <p style="color: rgba(255,255,255,0.3); font-size: 10px; font-family: sans-serif; margin-top: 2px;">{s.l}</p>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Ekran 2: Sonsuz Mod -->
                <div class="phone-shot" data-shot="2">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #0a0a1a 0%, #0f0f2a 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px;">
                      <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif; margin-bottom: 4px;">SONSUZ MOD</p>
                      <p style="color: #fff; font-size: 18px; font-weight: 700; font-family: sans-serif; margin-bottom: 16px;">∞ Bitmez, Tükenmez</p>
                      <div style="text-align: center; padding: 20px 0 16px;">
                        <p style="font-size: 64px; line-height: 1; background: linear-gradient(135deg, #22D3EE, #6366F1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">∞</p>
                      </div>
                      <div style="display: flex; flex-direction: column; gap: 8px;">
                        {[
                          { label: 'Rastgele Mahalle', color: '#22D3EE' },
                          { label: 'Rastgele İlçe', color: '#06B6D4' },
                          { label: 'Rastgele Şehir', color: '#0891B2' },
                          { label: 'Karışık', color: '#6366F1' },
                        ].map(opt => (
                          <div style={`display: flex; align-items: center; justify-content: space-between; background: ${opt.color}10; border: 1px solid ${opt.color}25; border-radius: 12px; padding: 10px 14px;`}>
                            <p style="color: #e2e8f0; font-size: 13px; font-family: sans-serif;">{opt.label}</p>
                            <div style={`width: 28px; height: 28px; border-radius: 50%; background: ${opt.color}; display: flex; align-items: center; justify-content: center;`}>
                              <div style="width: 0; height: 0; border-left: 7px solid white; border-top: 4px solid transparent; border-bottom: 4px solid transparent; margin-left: 2px;"></div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Ekran 3: Kesintisiz Mod -->
                <div class="phone-shot" data-shot="3">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #0f0a00 0%, #1a1200 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px;">
                      <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif; margin-bottom: 4px;">KESİNTİSİZ MOD</p>
                      <p style="color: #fff; font-size: 18px; font-weight: 700; font-family: sans-serif; margin-bottom: 14px;">Ne Kadar Gidebilirsin?</p>
                      <div style="background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.3); border-radius: 16px; padding: 16px; text-align: center; margin-bottom: 14px;">
                        <p style="color: rgba(255,255,255,0.4); font-size: 10px; font-family: sans-serif; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.1em;">Mevcut Seri</p>
                        <p style="color: #F59E0B; font-size: 48px; font-weight: 800; font-family: sans-serif; line-height: 1;">12</p>
                        <p style="color: rgba(255,255,255,0.3); font-size: 11px; font-family: sans-serif; margin-top: 4px;">bulmaca üst üste</p>
                      </div>
                      <div style="display: flex; justify-content: center; gap: 8px; margin-bottom: 14px;">
                        {[1,2,3].map(() => (
                          <div style="width: 36px; height: 36px; border-radius: 50%; background: rgba(239,68,68,0.15); border: 1.5px solid rgba(239,68,68,0.4); display: flex; align-items: center; justify-content: center; font-size: 18px;">❤️</div>
                        ))}
                      </div>
                      <div style="display: flex; gap: 8px;">
                        {[{v:'38',c:'#F59E0B',l:'En İyi Seri'},{v:'247',c:'#22D3EE',l:'Toplam Çözülen'}].map(s => (
                          <div style="flex: 1; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 12px; padding: 10px; text-align: center;">
                            <p style={`color: ${s.c}; font-size: 22px; font-weight: 800; font-family: sans-serif; line-height: 1;`}>{s.v}</p>
                            <p style="color: rgba(255,255,255,0.3); font-size: 10px; font-family: sans-serif; margin-top: 3px;">{s.l}</p>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Ekran 4: Game Center -->
                <div class="phone-shot" data-shot="4">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #080a14 0%, #0e1220 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px;">
                      <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif; margin-bottom: 4px;">SKOR TABLOSU</p>
                      <p style="color: #fff; font-size: 18px; font-weight: 700; font-family: sans-serif; margin-bottom: 12px;">Game Center</p>
                      <div style="display: flex; gap: 4px; background: rgba(255,255,255,0.05); border-radius: 10px; padding: 3px; margin-bottom: 14px;">
                        <div style="flex: 1; background: #22D3EE; border-radius: 7px; padding: 6px; text-align: center;">
                          <p style="color: #000; font-size: 12px; font-weight: 700; font-family: sans-serif;">Yerel</p>
                        </div>
                        <div style="flex: 1; border-radius: 7px; padding: 6px; text-align: center;">
                          <p style="color: rgba(255,255,255,0.4); font-size: 12px; font-family: sans-serif;">Global</p>
                        </div>
                      </div>
                      <div style="display: flex; flex-direction: column; gap: 6px;">
                        {[
                          { rank: 1, name: 'Ahmet K.', score: '1.842', medal: '🥇', isMe: false },
                          { rank: 2, name: 'Zeynep A.', score: '1.654', medal: '🥈', isMe: false },
                          { rank: 3, name: 'Mehmet Y.', score: '1.521', medal: '🥉', isMe: false },
                          { rank: 4, name: 'Sen', score: '1.203', medal: null, isMe: true },
                          { rank: 5, name: 'Ayşe T.', score: '1.102', medal: null, isMe: false },
                        ].map(row => (
                          <div style={`display: flex; align-items: center; gap: 10px; border-radius: 12px; padding: 9px 12px; ${row.isMe ? 'background: rgba(34,211,238,0.12); border: 1px solid rgba(34,211,238,0.3);' : 'background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);'}`}>
                            <p style="color: rgba(255,255,255,0.3); font-size: 12px; font-family: sans-serif; width: 16px; text-align: center;">{row.medal ?? row.rank}</p>
                            <p style={`font-size: 13px; font-family: sans-serif; flex: 1; ${row.isMe ? 'color: #22D3EE; font-weight: 700;' : 'color: #e2e8f0;'}`}>{row.name}</p>
                            <p style={`font-size: 12px; font-weight: 700; font-family: sans-serif; ${row.isMe ? 'color: #22D3EE;' : 'color: rgba(255,255,255,0.5);'}`}>{row.score}</p>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── Alt bağlantılar ───────────────────── -->
    <div class="page-footer-strip">
      <p class="page-footer-note">Yakında App Store ve Google Play'de</p>
      <div class="page-footer-links">
        <a href="/gezdoku/privacy-policy" class="page-footer-link">Gizlilik Politikası</a>
        <a href="/gezdoku/terms" class="page-footer-link">Kullanım Koşulları</a>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ───────────────────────────────── */
  .hero-section {
    position: relative; padding: 88px 24px 72px;
    text-align: center; overflow: hidden;
    background-color: var(--bg-section-alt);
    background-image: radial-gradient(var(--dot-color) 1.5px, transparent 1.5px);
    background-size: 28px 28px;
  }
  .hero-glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(circle at 50% 50%, rgba(34,211,238,0.08) 0%, transparent 65%);
  }
  .hero-inner {
    position: relative; z-index: 10;
    max-width: 640px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 24px;
  }
  .hero-logo {
    width: 96px; height: 96px; border-radius: 22px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.3); object-fit: contain;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 3.75rem); font-weight: 700;
    color: var(--color-text); margin-bottom: 14px;
    line-height: 1.08; letter-spacing: -0.02em;
  }
  .hero-desc {
    font-size: 1.1rem; color: var(--color-muted);
    line-height: 1.7; max-width: 460px; margin: 0 auto;
  }

  /* ── Coming soon badge ──────────────────── */
  .badge-coming-soon {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(34,211,238,0.1); border: 1px solid rgba(34,211,238,0.25);
    border-radius: 100px; padding: 8px 20px;
  }
  .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: #22D3EE; }
  .badge-text { font-size: 0.875rem; font-weight: 600; color: #22D3EE; }

  /* ── Social buttons ─────────────────────── */
  .social-row { display: flex; gap: 8px; }
  .social-btn {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    background: var(--hover-overlay); color: var(--color-muted);
    text-decoration: none; transition: background 0.15s, color 0.15s;
  }
  .social-btn:hover { background: rgba(160,0,32,0.12); color: #A00020; }

  /* ── Divider ─────────────────────────────── */
  .page-divider { height: 1px; border: none; background: var(--border-faint); margin: 0; }

  /* ── Feature text ────────────────────────── */
  .feature-eyebrow {
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: #A00020; margin-bottom: 16px;
  }
  .feature-heading {
    font-size: clamp(2rem, 4vw, 2.5rem); font-weight: 700;
    color: var(--color-text); margin-bottom: 8px; line-height: 1.15;
  }
  .feature-sub { font-size: 1.05rem; font-weight: 500; margin-bottom: 20px; opacity: 0.9; }
  .feature-desc { font-size: 1.05rem; color: var(--color-muted); line-height: 1.75; }

  /* ── Bottom strip ────────────────────────── */
  .page-footer-strip {
    max-width: 1152px; margin: 0 auto;
    padding: 32px 24px 64px;
    border-top: 1px solid var(--border-faint);
    display: flex; flex-direction: column; align-items: center; gap: 16px;
  }
  .page-footer-note { font-size: 0.875rem; color: var(--color-subtle); }
  .page-footer-links { display: flex; gap: 24px; }
  .page-footer-link {
    font-size: 0.875rem; color: var(--color-subtle); text-decoration: none;
    transition: color 0.15s ease;
  }
  .page-footer-link:hover { color: var(--color-text); }

  /* ── Phone mockup ────────────────────────── */
  .scroll-grid { display: grid; grid-template-columns: 1fr; }
  @media (min-width: 1024px) {
    .scroll-grid { grid-template-columns: 1fr 1fr; gap: 80px; }
  }
  .phone-sticky-col { display: none; }
  @media (min-width: 1024px) {
    .phone-sticky-col {
      display: block; position: sticky; top: 0;
      align-self: start; height: 100vh;
    }
  }
  .phone-frame {
    width: 260px; height: 540px;
    background: linear-gradient(145deg, #2c2c2e, #1c1c1e);
    border-radius: 50px; border: 1.5px solid rgba(255,255,255,0.12);
    box-shadow: 0 0 0 1px rgba(0,0,0,0.6), 0 40px 80px rgba(0,0,0,0.7), inset 0 1px 0 rgba(255,255,255,0.08);
    position: relative; padding: 13px;
  }
  .phone-island {
    position: absolute; top: 13px; left: 50%; transform: translateX(-50%);
    width: 100px; height: 32px; background: #000; border-radius: 18px; z-index: 10;
  }
  .phone-screen {
    width: 100%; height: 100%; border-radius: 38px;
    overflow: hidden; background: #000; position: relative;
  }
  .phone-shot { position: absolute; inset: 0; opacity: 0; transition: opacity 0.55s cubic-bezier(0.4, 0, 0.2, 1); }
  .phone-shot.active { opacity: 1; }
  .shot-ui { width: 100%; height: 100%; display: flex; flex-direction: column; }
  .shot-statusbar { height: 46px; flex-shrink: 0; }
</style>

<script>
  const features = document.querySelectorAll<HTMLElement>('.scroll-feature');
  const shots = document.querySelectorAll<HTMLElement>('.phone-shot');

  function setActive(index: number) {
    shots.forEach((s, i) => s.classList.toggle('active', i === index));
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const idx = parseInt((entry.target as HTMLElement).dataset.index ?? '0', 10);
          setActive(idx);
        }
      });
    },
    { threshold: 0.5 }
  );
  features.forEach((f) => observer.observe(f));
</script>
