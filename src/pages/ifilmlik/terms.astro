---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const accent = '#C41A1A';
const lastUpdated = '2 Haziran 2025';

const sections = [
  {
    title: 'Kabul',
    content: 'iFilmlik uygulamasını indirerek veya kullanarak bu kullanım koşullarını kabul etmiş sayılırsınız. Koşulları kabul etmiyorsanız lütfen uygulamayı kullanmayınız.',
  },
  {
    title: 'Hizmetin Kapsamı',
    content: 'iFilmlik; film ve dizi takip, izleme listesi oluşturma ve yapay zeka destekli öneri (iFi) hizmetleri sunar. Hizmet içeriği önceden bildirim yapılmaksızın değiştirilebilir veya kısıtlanabilir.',
  },
  {
    title: 'Kullanıcı Hesabı',
    content: 'Apple veya Google ile kimlik doğrulaması yaparak hesap oluşturabilirsiniz. Hesabınızın güvenliğinden siz sorumlusunuz. Şüpheli bir etkinlik fark ederseniz lütfen bizimle iletişime geçin.',
  },
  {
    title: 'Fikri Mülkiyet',
    content: 'Uygulama arayüzü, tasarımı ve özgün içerikleri Company Software App\'e aittir. Film ve dizi verileri TMDB API\'si aracılığıyla lisanslı olarak kullanılmaktadır; bu veriler üzerindeki haklar ilgili sahiplerine aittir.',
  },
  {
    title: 'Kabul Edilemez Kullanım',
    content: 'Uygulamayı yasadışı amaçlarla, başkalarının haklarını ihlal edecek biçimde veya hizmetin bütünlüğünü bozacak şekilde kullanamazsınız. Bu tür kullanımlar hesap askıya alınması veya silinmesiyle sonuçlanabilir.',
  },
  {
    title: 'Sorumluluk Reddi',
    content: 'iFilmlik "olduğu gibi" sunulmaktadır. Kesintisiz veya hatasız bir hizmet garanti edilmez. Uygulama, TMDB ve Google Gemini gibi üçüncü taraf hizmetlerin kullanılabilirliğine bağlıdır.',
  },
  {
    title: 'Hesap Silme',
    content: 'Hesabınızı ve tüm verilerinizi kalıcı olarak silmek için uygulama içindeki Profil sayfasına gidin ve "Üyeliği Sil" seçeneğini kullanın. Bu işlem geri alınamaz.',
  },
  {
    title: 'Değişiklikler',
    content: 'Bu koşullar zaman zaman güncellenebilir. Önemli değişiklikler uygulama içi bildirim aracılığıyla duyurulur. Uygulamayı kullanmaya devam etmeniz güncel koşulları kabul ettiğiniz anlamına gelir.',
  },
  {
    title: 'Geçerli Hukuk',
    content: 'Bu kullanım koşulları Türkiye Cumhuriyeti kanunlarına tabidir. Anlaşmazlıklarda İstanbul mahkemeleri yetkilidir.',
  },
  {
    title: 'İletişim',
    content: 'Kullanım koşullarına ilişkin sorularınız için bizimle iletişime geçebilirsiniz:',
    email: 'support@companysoftware.app',
  },
];
---

<Layout
  title="iFilmlik — Kullanım Koşulları"
  description="iFilmlik uygulaması kullanım koşulları ve hizmet şartları."
>
  <Header />

  <main class="doc-page">

    <section class="doc-hero">
      <div class="doc-hero-inner">
        <a href="/ifilmlik" class="doc-app-link">
          <img src="/images/logo-ifilmlik.png" alt="iFilmlik" class="doc-app-logo" />
          <span class="doc-app-name">iFilmlik</span>
        </a>
        <h1 class="doc-title">Kullanım Koşulları</h1>
        <p class="doc-date">Son güncelleme: <span style={`color:${accent};`}>{lastUpdated}</span></p>
        <p class="doc-intro">iFilmlik'i kullanmadan önce lütfen aşağıdaki koşulları okuyunuz.</p>
      </div>
    </section>

    <div class="doc-body">
      {sections.map((s, i) => (
        <div class="doc-section">
          <div class="doc-num-wrap" style={`background:${accent}10; border:1px solid ${accent}25;`}>
            <span class="doc-num" style={`color:${accent};`}>{i + 1}</span>
          </div>
          <div class="doc-content">
            <h2>{s.title}</h2>
            <p>{s.content}</p>
            {s.email && (
              <a href={`mailto:${s.email}`} class="doc-link" style={`color:${accent};`}>
                {s.email}
              </a>
            )}
          </div>
        </div>
      ))}

      <div class="doc-back">
        <a href="/ifilmlik">← iFilmlik'e Dön</a>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  .doc-page { padding-top: 48px; }

  .doc-hero {
    padding: 64px 24px 56px;
    text-align: center;
    background: var(--bg-section-alt);
    border-bottom: 1px solid var(--border-faint);
  }
  .doc-hero-inner {
    max-width: 640px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 14px;
  }
  .doc-app-link {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; margin-bottom: 4px;
  }
  .doc-app-logo { width: 44px; height: 44px; border-radius: 10px; }
  .doc-app-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem; font-weight: 600;
    color: var(--color-text);
  }
  .doc-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700; line-height: 1.2;
    color: var(--color-text);
  }
  .doc-date { font-size: 0.875rem; color: var(--color-subtle); }
  .doc-intro {
    font-size: 0.95rem; color: var(--color-muted);
    line-height: 1.7; max-width: 500px;
  }

  .doc-body {
    max-width: 720px; margin: 0 auto;
    padding: 48px 24px 80px;
  }
  .doc-section {
    display: flex; gap: 20px;
    padding: 32px 0;
    border-bottom: 1px solid var(--border-faint);
  }
  .doc-section:last-of-type { border-bottom: none; }

  .doc-num-wrap {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 2px;
  }
  .doc-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem; font-weight: 700;
  }
  .doc-content { flex: 1; }
  .doc-content h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.05rem; font-weight: 600;
    color: var(--color-text); margin-bottom: 10px;
  }
  .doc-content p {
    font-size: 0.9rem; color: var(--color-muted); line-height: 1.75;
  }
  .doc-link {
    display: inline-block; margin-top: 10px;
    font-size: 0.9rem; font-weight: 500;
    text-decoration: none; transition: opacity 0.15s ease;
  }
  .doc-link:hover { opacity: 0.7; }

  .doc-back { margin-top: 48px; text-align: center; }
  .doc-back a {
    font-size: 0.875rem; color: var(--color-subtle);
    text-decoration: none; transition: color 0.15s ease;
  }
  .doc-back a:hover { color: var(--color-muted); }
</style>
