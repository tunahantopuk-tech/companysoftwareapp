---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const storeUrl = 'https://apps.apple.com/us/app/ifilmlik/id6760693864';

const scrollFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 8v4l3 3"/><path d="M9.1 2.4C7 3.4 5 5.1 3.8 7.3"/><path d="M3 12H1"/></svg>`,
    title: 'Asistan iFi',
    sub: 'Filmini Bul, Film Önersin',
    description: 'Yapay zeka destekli film asistanın iFi, aradığın filmi bulur ve sana özel öneriler sunar.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="3"/><path d="M8 11h2m4 0h2"/><circle cx="12" cy="14" r="1.5"/><path d="M12 3v4"/><path d="M8 3l4 4 4-4"/></svg>`,
    title: 'Mini Oyunlar',
    sub: 'Sessiz Sinema, Anlat Bakalım, iFishing, DedektiFi, iFiMoji',
    description: 'Beş farklı mini oyunla film bilgini test et, arkadaşlarınla yarış, eğlenceyi bir üst seviyeye taşı.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: 'Keşfet',
    sub: 'Aradığını Bul, Hemen Bul',
    description: 'Güçlü arama ve keşif ekranıyla istediğin içeriğe saniyeler içinde ulaş.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>`,
    title: 'Liste',
    sub: 'Listeni Oluştur ve Rozet Kazan',
    description: 'Kendi film listelerini oluştur, tamamladıkça rozet kazan, başarılarını sergile.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h20M2 12h20M2 17h20"/><rect x="3" y="3" width="4" height="4" rx="1"/><rect x="10" y="3" width="4" height="4" rx="1"/><rect x="17" y="3" width="4" height="4" rx="1"/></svg>`,
    title: 'Detaylar',
    sub: 'Platformlarda Kaybolma',
    description: 'Her film ve dizi için hangi platformda olduğunu anında gör. Artık nerede izleyeceğini aramaya son.',
  },
];
---

<Layout
  title="iFilmlik | Film ve Dizi Takip Uygulaması"
  description="Film ve dizi takip uygulaması. İzlediğiniz ve izleyeceğiniz her şeyi tek yerde takip edin. App Store'da ücretsiz."
  ogImage="/images/logo-ifilmlik.png"
>
  <Header />

  <main style="padding-top: 56px;">

    <!-- ── Hero ──────────────────────────────────── -->
    <section class="hero-section">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-inner">
        <img
          src="/images/logo-ifilmlik.png"
          alt="iFilmlik"
          width="96" height="96"
          class="hero-logo"
        />
        <div>
          <h1 class="hero-title font-heading">iFilmlik</h1>
          <p class="hero-desc">
            Film ve dizi takip uygulaması. İzlediğiniz ve izleyeceğiniz her şeyi tek yerde takip edin.
          </p>
        </div>
        <a href={storeUrl} target="_blank" rel="noopener noreferrer" class="appstore-badge">
          <svg class="badge-apple-svg" viewBox="0 0 24 24" fill="white">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"/>
          </svg>
          <div class="badge-text-wrap">
            <span class="badge-line1">Download on the</span>
            <span class="badge-line2">App Store</span>
          </div>
        </a>
        <div class="social-row">
          <a href="#" class="social-btn" aria-label="iFilmlik Instagram" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="social-btn" aria-label="iFilmlik X" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </section>

    <hr class="page-divider" />

    <!-- ── Scroll features ────────────────────── -->
    <section style="max-width: 1152px; margin: 0 auto; padding: 32px 24px;">
      <div class="scroll-grid">

        <div>
          {scrollFeatures.map((f, i) => (
            <div class="scroll-feature" data-index={i} style="min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 64px 0; max-width: 420px;">
              <div class="feature-icon-wrap" set:html={f.icon} />
              <p class="feature-eyebrow">iFilmlik</p>
              <h2 class="feature-heading font-heading">{f.title}</h2>
              <p class="feature-sub font-heading">{f.sub}</p>
              <p class="feature-desc">{f.description}</p>
            </div>
          ))}
        </div>

        <!-- Sticky phone -->
        <div class="phone-sticky-col">
          <div style="display: flex; align-items: center; justify-content: center; height: 100%;">
            <div class="phone-frame">
              <!-- Buttons -->
              <div class="phone-button phone-button-left" style="top: 140px; height: 32px;"></div>
              <div class="phone-button phone-button-left" style="top: 190px; height: 52px;"></div>
              <div class="phone-button phone-button-left" style="top: 256px; height: 52px;"></div>
              <div class="phone-button phone-button-right" style="top: 180px; height: 82px;"></div>

              <div class="phone-island"></div>
              <div class="phone-screen">

                <!-- Ekran 0: Asistan iFi -->
                <div class="phone-shot active" data-shot="0">
                  <img src="/images/ifilmlik/screen-0.png" alt="Asistan iFi" class="screenshot-img" />
                </div>

                <!-- Ekran 1: Mini Oyunlar -->
                <div class="phone-shot" data-shot="1">
                  <img src="/images/ifilmlik/screen-1.png" alt="Mini Oyunlar" class="screenshot-img" />
                </div>

                <!-- Ekran 2: Keşfet -->
                <div class="phone-shot" data-shot="2">
                  <img src="/images/ifilmlik/screen-2.png" alt="Keşfet" class="screenshot-img" />
                </div>

                <!-- Ekran 3: Liste -->
                <div class="phone-shot" data-shot="3">
                  <img src="/images/ifilmlik/screen-3.png" alt="Liste" class="screenshot-img" />
                </div>

                <!-- Ekran 4: Detaylar -->
                <div class="phone-shot" data-shot="4">
                  <img src="/images/ifilmlik/screen-4.png" alt="Detaylar" class="screenshot-img" />
                </div>

              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── Alt bağlantılar ───────────────────── -->
    <div class="page-footer-strip">
      <a href={storeUrl} target="_blank" rel="noopener noreferrer" class="appstore-badge appstore-badge-sm">
        <svg class="badge-apple-svg" style="width:20px;height:20px;" viewBox="0 0 24 24" fill="white">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"/>
        </svg>
        <div class="badge-text-wrap">
          <span class="badge-line1">Download on the</span>
          <span class="badge-line2" style="font-size:16px;">App Store</span>
        </div>
      </a>
      <div class="page-footer-links">
        <a href="/ifilmlik/about" class="page-footer-link">Hakkında</a>
        <a href="/ifilmlik/privacy-policy" class="page-footer-link">Gizlilik Politikası</a>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ───────────────────────────────── */
  .hero-section {
    position: relative;
    padding: 88px 24px 72px;
    text-align: center;
    overflow: hidden;
    background-color: var(--bg-section-alt);
    background-image: radial-gradient(var(--dot-color) 1.5px, transparent 1.5px);
    background-size: 28px 28px;
  }
  .hero-glow {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none;
    background: radial-gradient(circle at 50% 50%, rgba(160,0,32,0.10) 0%, transparent 65%);
  }
  .hero-inner {
    position: relative; z-index: 10;
    max-width: 640px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 24px;
  }
  .hero-logo {
    width: 96px; height: 96px;
    border-radius: 22px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.3);
    object-fit: contain;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 14px;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }
  .hero-desc {
    font-size: 1.1rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 460px;
    margin: 0 auto;
  }

  /* ── App Store badge ────────────────────── */
  .appstore-badge {
    display: inline-flex; align-items: center; gap: 12px;
    background: #000;
    border: 1.5px solid rgba(255,255,255,0.28);
    border-radius: 14px; padding: 10px 22px;
    color: #fff; text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .appstore-badge:hover { opacity: 0.84; transform: translateY(-1px); }
  .badge-apple-svg { width: 26px; height: 26px; flex-shrink: 0; }
  .badge-text-wrap { display: flex; flex-direction: column; }
  .badge-line1 { font-size: 10px; color: rgba(255,255,255,0.75); font-family: sans-serif; line-height: 1.2; }
  .badge-line2 { font-size: 20px; font-weight: 700; font-family: sans-serif; line-height: 1.2; letter-spacing: -0.01em; }

  /* ── Feature icon ────────────────────────── */
  .feature-icon-wrap {
    width: 44px; height: 44px;
    color: #A00020;
    margin-bottom: 20px;
  }
  .feature-icon-wrap svg { width: 100%; height: 100%; }

  /* ── Social buttons ─────────────────────── */
  .social-row { display: flex; gap: 8px; }
  .social-btn {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    background: var(--hover-overlay);
    color: var(--color-muted);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .social-btn:hover { background: rgba(160,0,32,0.12); color: #A00020; }

  /* ── Divider ─────────────────────────────── */
  .page-divider { height: 1px; border: none; background: var(--border-faint); margin: 0; }

  /* ── Feature text ────────────────────────── */
  .feature-eyebrow {
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: #A00020; margin-bottom: 16px;
  }
  .feature-heading {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 700; color: var(--color-text);
    margin-bottom: 8px; line-height: 1.15;
  }
  .feature-sub {
    font-size: 1.05rem; font-weight: 500;
    color: #818CF8; margin-bottom: 20px;
  }
  .feature-desc {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.75;
  }

  /* ── Bottom strip ────────────────────────── */
  .page-footer-strip {
    max-width: 1152px; margin: 0 auto;
    padding: 32px 24px 64px;
    border-top: 1px solid var(--border-faint);
    display: flex; flex-direction: column; align-items: center; gap: 16px;
  }
  .page-footer-links { display: flex; gap: 24px; }
  .page-footer-link {
    font-size: 0.875rem; color: var(--color-subtle); text-decoration: none;
    transition: color 0.15s ease;
  }
  .page-footer-link:hover { color: var(--color-text); }

  /* ── Phone mockup ────────────────────────── */
  .scroll-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 1024px) {
    .scroll-grid {
      grid-template-columns: 1fr 1fr;
      gap: 80px;
    }
  }

  .phone-sticky-col {
    display: flex;
    justify-content: center;
    padding: 40px 0;
  }

  @media (min-width: 1024px) {
    .phone-sticky-col {
      position: sticky;
      top: 0;
      align-self: start;
      height: 100vh;
      padding: 0;
    }
  }

  @media (max-width: 1023px) {
    .scroll-feature {
      min-height: auto !important;
      padding: 32px 0 !important;
      text-align: center;
    }
  }

  /* iPhone 17 Pro Max Design */
  .phone-frame {
    width: 300px;
    height: 620px;
    position: relative;
    background: linear-gradient(145deg, #3a3a3c 0%, #1c1c1e 50%, #2c2c2e 100%);
    border-radius: 58px;
    padding: 4px;
    box-shadow:
      0 0 0 0.5px rgba(255,255,255,0.05),
      0 2px 4px rgba(0,0,0,0.2),
      0 8px 16px rgba(0,0,0,0.25),
      0 24px 48px rgba(0,0,0,0.35),
      0 48px 96px rgba(0,0,0,0.4),
      inset 0 0 0 1px rgba(255,255,255,0.02),
      inset 0 1px 2px rgba(255,255,255,0.08);
    transform: perspective(1000px) rotateY(0deg);
    transition: transform 0.3s ease;
  }

  .phone-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 58px;
    padding: 2px;
    background: linear-gradient(135deg,
      rgba(255,255,255,0.1) 0%,
      rgba(255,255,255,0.05) 25%,
      transparent 50%,
      rgba(0,0,0,0.1) 75%,
      rgba(0,0,0,0.2) 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .phone-frame::after {
    content: '';
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 3px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(255,255,255,0.15) 20%,
      rgba(255,255,255,0.25) 50%,
      rgba(255,255,255,0.15) 80%,
      transparent 100%
    );
    border-radius: 0 0 4px 4px;
    opacity: 0.6;
  }

  .phone-island {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: 126px;
    height: 37px;
    background: #000;
    border-radius: 24px;
    z-index: 10;
    box-shadow:
      inset 0 1px 2px rgba(0,0,0,0.8),
      inset 0 -1px 1px rgba(255,255,255,0.05),
      0 2px 8px rgba(0,0,0,0.6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 12px;
  }

  .phone-island::before {
    content: '';
    width: 12px;
    height: 12px;
    background: radial-gradient(circle, #1a1a2e 0%, #000 70%);
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.5);
  }

  .phone-island::after {
    content: '';
    width: 12px;
    height: 12px;
    background: radial-gradient(circle, #0a1a2a 0%, #000 70%);
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.5);
  }

  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 54px;
    overflow: hidden;
    background: #000;
    position: relative;
    padding: 8px;
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,0.03),
      inset 0 2px 4px rgba(0,0,0,0.4);
  }

  .phone-screen::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg,
      rgba(255,255,255,0.05) 0%,
      transparent 40%,
      transparent 60%,
      rgba(0,0,0,0.1) 100%
    );
    pointer-events: none;
    z-index: 5;
    opacity: 0.3;
  }

  /* Phone Buttons */
  .phone-button {
    position: absolute;
    width: 3px;
    background: linear-gradient(90deg,
      rgba(255,255,255,0.1) 0%,
      rgba(100,100,100,0.8) 50%,
      rgba(50,50,50,0.6) 100%
    );
    border-radius: 0 2px 2px 0;
    box-shadow:
      inset 0 1px 1px rgba(255,255,255,0.2),
      inset 0 -1px 1px rgba(0,0,0,0.5),
      1px 0 2px rgba(0,0,0,0.3);
  }

  .phone-button-left {
    left: -3px;
    border-radius: 2px 0 0 2px;
    background: linear-gradient(90deg,
      rgba(50,50,50,0.6) 0%,
      rgba(100,100,100,0.8) 50%,
      rgba(255,255,255,0.1) 100%
    );
    box-shadow:
      inset 0 1px 1px rgba(255,255,255,0.2),
      inset 0 -1px 1px rgba(0,0,0,0.5),
      -1px 0 2px rgba(0,0,0,0.3);
  }

  .phone-button-right {
    right: -3px;
  }

  /* Mobile Phone Size */
  @media (max-width: 1023px) {
    .phone-frame {
      width: 240px;
      height: 496px;
    }

    .phone-island {
      width: 100px;
      height: 30px;
    }

    .phone-button {
      display: none;
    }
  }

  .phone-shot {
    position: absolute;
    inset: 8px;
    opacity: 0;
    transition: opacity 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 46px;
    overflow: hidden;
  }
  .phone-shot.active { opacity: 1; }
  .shot-ui { width: 100%; height: 100%; display: flex; flex-direction: column; }
  .shot-statusbar { height: 46px; flex-shrink: 0; }
  .screenshot-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    background: #000;
  }
</style>

<script>
  const features = document.querySelectorAll<HTMLElement>('.scroll-feature');
  const shots = document.querySelectorAll<HTMLElement>('.phone-shot');

  function setActive(index: number) {
    shots.forEach((s, i) => s.classList.toggle('active', i === index));
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const idx = parseInt((entry.target as HTMLElement).dataset.index ?? '0', 10);
          setActive(idx);
        }
      });
    },
    { threshold: 0.5 }
  );
  features.forEach((f) => observer.observe(f));
</script>
