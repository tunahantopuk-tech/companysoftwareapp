---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const storeUrl = 'https://apps.apple.com/us/app/ifilmlik/id6760693864';

const scrollFeatures = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 8v4l3 3"/><path d="M9.1 2.4C7 3.4 5 5.1 3.8 7.3"/><path d="M3 12H1"/></svg>`,
    title: 'Asistan iFi',
    sub: 'Filmini Bul, Film Önersin',
    description: 'Yapay zeka destekli film asistanın iFi, aradığın filmi bulur ve sana özel öneriler sunar.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="3"/><path d="M8 11h2m4 0h2"/><circle cx="12" cy="14" r="1.5"/><path d="M12 3v4"/><path d="M8 3l4 4 4-4"/></svg>`,
    title: 'Mini Oyunlar',
    sub: 'Sessiz Sinema, Anlat Bakalım, iFishing, DedektiFi, iFiMoji',
    description: 'Beş farklı mini oyunla film bilgini test et, arkadaşlarınla yarış, eğlenceyi bir üst seviyeye taşı.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: 'Keşfet',
    sub: 'Aradığını Bul, Hemen Bul',
    description: 'Güçlü arama ve keşif ekranıyla istediğin içeriğe saniyeler içinde ulaş.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>`,
    title: 'Liste',
    sub: 'Listeni Oluştur ve Rozet Kazan',
    description: 'Kendi film listelerini oluştur, tamamladıkça rozet kazan, başarılarını sergile.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h20M2 12h20M2 17h20"/><rect x="3" y="3" width="4" height="4" rx="1"/><rect x="10" y="3" width="4" height="4" rx="1"/><rect x="17" y="3" width="4" height="4" rx="1"/></svg>`,
    title: 'Detaylar',
    sub: 'Platformlarda Kaybolma',
    description: 'Her film ve dizi için hangi platformda olduğunu anında gör. Artık nerede izleyeceğini aramaya son.',
  },
];
---

<Layout
  title="iFilmlik | Film ve Dizi Takip Uygulaması"
  description="Film ve dizi takip uygulaması. İzlediğiniz ve izleyeceğiniz her şeyi tek yerde takip edin. App Store'da ücretsiz."
  ogImage="/images/logo-ifilmlik.png"
>
  <Header />

  <main style="padding-top: 56px;">

    <!-- ── Hero ──────────────────────────────────── -->
    <section class="hero-section">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-inner">
        <img
          src="/images/logo-ifilmlik.png"
          alt="iFilmlik"
          width="96" height="96"
          class="hero-logo"
        />
        <div>
          <h1 class="hero-title font-heading">iFilmlik</h1>
          <p class="hero-desc">
            Film ve dizi takip uygulaması. İzlediğiniz ve izleyeceğiniz her şeyi tek yerde takip edin.
          </p>
        </div>
        <a href={storeUrl} target="_blank" rel="noopener noreferrer" class="appstore-badge">
          <svg class="badge-apple-svg" viewBox="0 0 24 24" fill="white">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"/>
          </svg>
          <div class="badge-text-wrap">
            <span class="badge-line1">Download on the</span>
            <span class="badge-line2">App Store</span>
          </div>
        </a>
        <div class="social-row">
          <a href="#" class="social-btn" aria-label="iFilmlik Instagram" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="social-btn" aria-label="iFilmlik X" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </section>

    <hr class="page-divider" />

    <!-- ── Scroll features ────────────────────── -->
    <section style="max-width: 1152px; margin: 0 auto; padding: 32px 24px;">
      <div class="scroll-grid">

        <div>
          {scrollFeatures.map((f, i) => (
            <div class="scroll-feature" data-index={i} style="min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 64px 0; max-width: 420px;">
              <div class="feature-icon-wrap" set:html={f.icon} />
              <p class="feature-eyebrow">iFilmlik</p>
              <h2 class="feature-heading font-heading">{f.title}</h2>
              <p class="feature-sub font-heading">{f.sub}</p>
              <p class="feature-desc">{f.description}</p>
            </div>
          ))}
        </div>

        <!-- Sticky phone -->
        <div class="phone-sticky-col">
          <div style="display: flex; align-items: center; justify-content: center; height: 100%;">
            <div class="phone-frame">
              <div class="phone-island"></div>
              <div class="phone-screen">

                <!-- Ekran 0: Asistan iFi -->
                <div class="phone-shot active" data-shot="0">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #0d0820 0%, #1a0f35 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px; display: flex; flex-direction: column; height: calc(100% - 46px);">
                      <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif; margin-bottom: 4px;">ASISTAN</p>
                      <p style="color: #fff; font-size: 18px; font-weight: 700; font-family: sans-serif; margin-bottom: 14px;">iFi</p>
                      <div style="display: flex; flex-direction: column; gap: 8px; flex: 1;">
                        <div style="align-self: flex-end; background: rgba(99,102,241,0.8); border-radius: 16px 16px 4px 16px; padding: 8px 12px; max-width: 80%;">
                          <p style="color: #fff; font-size: 12px; font-family: sans-serif;">Bilim kurgu filmi önerir misin?</p>
                        </div>
                        <div style="align-self: flex-start; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px 16px 16px 4px; padding: 8px 12px; max-width: 85%;">
                          <p style="color: #e2e8f0; font-size: 12px; font-family: sans-serif; line-height: 1.5;">Tabii! Interstellar, Dune ve Arrival harika seçenekler. Hangisini izlemek istersin?</p>
                        </div>
                        <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px;">
                          {['Interstellar', 'Dune', 'Arrival'].map(chip => (
                            <div style="background: rgba(99,102,241,0.2); border: 1px solid rgba(99,102,241,0.4); border-radius: 20px; padding: 5px 10px;">
                              <p style="color: #818CF8; font-size: 11px; font-family: sans-serif;">{chip}</p>
                            </div>
                          ))}
                        </div>
                        <div style="align-self: flex-end; background: rgba(99,102,241,0.8); border-radius: 16px 16px 4px 16px; padding: 8px 12px; max-width: 80%; margin-top: 4px;">
                          <p style="color: #fff; font-size: 12px; font-family: sans-serif;">Interstellar</p>
                        </div>
                      </div>
                      <div style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 10px 14px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                        <p style="color: rgba(255,255,255,0.25); font-size: 12px; font-family: sans-serif; flex: 1;">Film veya dizi sor…</p>
                        <div style="width: 28px; height: 28px; background: #6366F1; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                          <div style="width: 0; height: 0; border-left: 6px solid white; border-top: 4px solid transparent; border-bottom: 4px solid transparent; margin-left: 2px;"></div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Ekran 1: Mini Oyunlar -->
                <div class="phone-shot" data-shot="1">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #071a12 0%, #0d2a1e 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px;">
                      <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif; margin-bottom: 4px;">EĞLENCE</p>
                      <p style="color: #fff; font-size: 18px; font-weight: 700; font-family: sans-serif; margin-bottom: 14px;">Mini Oyunlar</p>
                      <div style="display: flex; flex-direction: column; gap: 8px;">
                        {[
                          { name: 'Sessiz Sinema', color: '#10B981', icon: '🎭' },
                          { name: 'Anlat Bakalım', color: '#F59E0B', icon: '💬' },
                          { name: 'iFishing', color: '#3B82F6', icon: '🎣' },
                          { name: 'DedektiFi', color: '#8B5CF6', icon: '🔍' },
                          { name: 'iFiMoji', color: '#EC4899', icon: '😎' },
                        ].map(game => (
                          <div style={`display: flex; align-items: center; gap: 12px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 10px 12px;`}>
                            <div style={`width: 40px; height: 40px; border-radius: 10px; background: ${game.color}25; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;`}>{game.icon}</div>
                            <p style="color: #e2e8f0; font-size: 13px; font-weight: 600; font-family: sans-serif;">{game.name}</p>
                            <div style="margin-left: auto; width: 8px; height: 8px; border-right: 2px solid rgba(255,255,255,0.2); border-top: 2px solid rgba(255,255,255,0.2); transform: rotate(45deg);"></div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Ekran 2: Keşfet -->
                <div class="phone-shot" data-shot="2">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #071520 0%, #0d2035 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px;">
                      <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif; margin-bottom: 4px;">KEŞFET</p>
                      <p style="color: #fff; font-size: 18px; font-weight: 700; font-family: sans-serif; margin-bottom: 12px;">Ara & Bul</p>
                      <div style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 9px 12px; display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                        <div style="width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.25); border-radius: 50%; flex-shrink: 0;"></div>
                        <p style="color: rgba(255,255,255,0.25); font-size: 12px; font-family: sans-serif;">Film, dizi, oyuncu ara…</p>
                      </div>
                      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px;">
                        {['#6366F1','#22D3EE','#F59E0B','#EC4899','#10B981','#8B5CF6','#3B82F6','#F97316','#6366F1'].map(color => (
                          <div style={`aspect-ratio: 2/3; border-radius: 8px; background: ${color}40; border: 1px solid ${color}30;`}></div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Ekran 3: Liste -->
                <div class="phone-shot" data-shot="3">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #110820 0%, #1c0d33 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px;">
                      <p style="color: rgba(255,255,255,0.4); font-size: 11px; font-family: sans-serif; margin-bottom: 4px;">LİSTELER</p>
                      <p style="color: #fff; font-size: 18px; font-weight: 700; font-family: sans-serif; margin-bottom: 14px;">Liste</p>
                      <div style="display: flex; flex-direction: column; gap: 7px; margin-bottom: 14px;">
                        {[
                          { label: 'En İyi Filmler', count: '24', done: true },
                          { label: '2024 Sineması', count: '12', done: true },
                          { label: 'Sci-Fi Favori', count: '8', done: false },
                          { label: 'Arkadaş Önerileri', count: '6', done: false },
                        ].map(item => (
                          <div style="display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 12px; padding: 9px 12px;">
                            <div style={`width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; ${item.done ? 'background: #7C3AED;' : 'border: 1.5px solid rgba(255,255,255,0.2);'}`}>
                              {item.done && <div style="width: 6px; height: 6px; background: white; border-radius: 50%;"></div>}
                            </div>
                            <p style="color: #e2e8f0; font-size: 12px; font-family: sans-serif; flex: 1;">{item.label}</p>
                            <p style="color: rgba(255,255,255,0.3); font-size: 11px; font-family: sans-serif;">{item.count}</p>
                          </div>
                        ))}
                      </div>
                      <p style="color: rgba(255,255,255,0.4); font-size: 10px; font-family: sans-serif; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.1em;">Rozetlerim</p>
                      <div style="display: flex; gap: 8px;">
                        {[{c:'#F59E0B',e:'🏆'},{c:'#6366F1',e:'⭐'},{c:'#10B981',e:'🎬'},{c:'#EC4899',e:'🎯'}].map(b => (
                          <div style={`width: 40px; height: 40px; border-radius: 50%; background: ${b.c}20; border: 1.5px solid ${b.c}50; display: flex; align-items: center; justify-content: center; font-size: 18px;`}>{b.e}</div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Ekran 4: Detaylar -->
                <div class="phone-shot" data-shot="4">
                  <div class="shot-ui" style="background: linear-gradient(180deg, #0a0a0f 0%, #12121a 100%);">
                    <div class="shot-statusbar"></div>
                    <div style="padding: 0 14px;">
                      <div style="width: 100%; aspect-ratio: 16/9; border-radius: 12px; background: linear-gradient(135deg, #1e1b4b, #312e81); margin-bottom: 12px; position: relative; overflow: hidden;">
                        <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.7) 100%);"></div>
                        <div style="position: absolute; bottom: 10px; left: 12px;">
                          <p style="color: #fff; font-size: 14px; font-weight: 700; font-family: sans-serif;">Film Başlığı</p>
                          <p style="color: rgba(255,255,255,0.5); font-size: 11px; font-family: sans-serif;">2024 • Aksiyon • 2s 18d</p>
                        </div>
                      </div>
                      <div style="display: flex; gap: 6px; margin-bottom: 12px;">
                        <div style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 5px 10px;">
                          <p style="color: #F59E0B; font-size: 12px; font-family: sans-serif; font-weight: 600;">★ 8.4</p>
                        </div>
                        <div style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 5px 10px;">
                          <p style="color: rgba(255,255,255,0.5); font-size: 12px; font-family: sans-serif;">IMDb</p>
                        </div>
                      </div>
                      <p style="color: rgba(255,255,255,0.4); font-size: 10px; font-family: sans-serif; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.1em;">Platformlar</p>
                      <div style="display: flex; flex-direction: column; gap: 6px;">
                        {[
                          { name: 'Netflix', color: '#E50914' },
                          { name: 'Prime Video', color: '#00A8E0' },
                          { name: 'Disney+', color: '#113CCF' },
                        ].map(p => (
                          <div style={`display: flex; align-items: center; gap: 10px; background: ${p.color}12; border: 1px solid ${p.color}30; border-radius: 10px; padding: 8px 12px;`}>
                            <div style={`width: 8px; height: 8px; border-radius: 50%; background: ${p.color}; flex-shrink: 0;`}></div>
                            <p style="color: #e2e8f0; font-size: 12px; font-family: sans-serif;">{p.name}</p>
                            <p style={`margin-left: auto; font-size: 11px; font-family: sans-serif; color: ${p.color};`}>İzle →</p>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ── Alt bağlantılar ───────────────────── -->
    <div class="page-footer-strip">
      <a href={storeUrl} target="_blank" rel="noopener noreferrer" class="appstore-badge appstore-badge-sm">
        <svg class="badge-apple-svg" style="width:20px;height:20px;" viewBox="0 0 24 24" fill="white">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"/>
        </svg>
        <div class="badge-text-wrap">
          <span class="badge-line1">Download on the</span>
          <span class="badge-line2" style="font-size:16px;">App Store</span>
        </div>
      </a>
      <div class="page-footer-links">
        <a href="/ifilmlik/about" class="page-footer-link">Hakkında</a>
        <a href="/ifilmlik/privacy-policy" class="page-footer-link">Gizlilik Politikası</a>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ───────────────────────────────── */
  .hero-section {
    position: relative;
    padding: 88px 24px 72px;
    text-align: center;
    overflow: hidden;
    background-color: var(--bg-section-alt);
    background-image: radial-gradient(var(--dot-color) 1.5px, transparent 1.5px);
    background-size: 28px 28px;
  }
  .hero-glow {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none;
    background: radial-gradient(circle at 50% 50%, rgba(160,0,32,0.10) 0%, transparent 65%);
  }
  .hero-inner {
    position: relative; z-index: 10;
    max-width: 640px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 24px;
  }
  .hero-logo {
    width: 96px; height: 96px;
    border-radius: 22px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.3);
    object-fit: contain;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 14px;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }
  .hero-desc {
    font-size: 1.1rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 460px;
    margin: 0 auto;
  }

  /* ── App Store badge ────────────────────── */
  .appstore-badge {
    display: inline-flex; align-items: center; gap: 12px;
    background: #000;
    border: 1.5px solid rgba(255,255,255,0.28);
    border-radius: 14px; padding: 10px 22px;
    color: #fff; text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .appstore-badge:hover { opacity: 0.84; transform: translateY(-1px); }
  .badge-apple-svg { width: 26px; height: 26px; flex-shrink: 0; }
  .badge-text-wrap { display: flex; flex-direction: column; }
  .badge-line1 { font-size: 10px; color: rgba(255,255,255,0.75); font-family: sans-serif; line-height: 1.2; }
  .badge-line2 { font-size: 20px; font-weight: 700; font-family: sans-serif; line-height: 1.2; letter-spacing: -0.01em; }

  /* ── Feature icon ────────────────────────── */
  .feature-icon-wrap {
    width: 44px; height: 44px;
    color: #A00020;
    margin-bottom: 20px;
  }
  .feature-icon-wrap svg { width: 100%; height: 100%; }

