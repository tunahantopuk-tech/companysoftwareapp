---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const apps = [
  {
    id: 'ifilmlik',
    name: 'iFilmlik',
    logo: '/images/logo-ifilmlik.png',
    description: 'Film ve dizi takip uygulaması. İzlediğiniz ve izleyeceğiniz her şeyi tek yerde takip edin.',
    pageHref: '/ifilmlik',
    storeUrl: 'https://apps.apple.com/us/app/ifilmlik/id6760693864',
    badge: null,
    badgeClass: '',
  },
  {
    id: 'gezdoku',
    name: 'GezDoku',
    logo: '/images/logo-gezdoku.png',
    description: 'Sizi farklı dünyalara götürecek yeni bir oyun deneyimi. Çok yakında.',
    pageHref: '/gezdoku',
    storeUrl: null,
    badge: 'Yakında',
    badgeClass: 'bg-cyan-500/10 text-cyan-400',
  },
  {
    id: 'oyunluk',
    name: 'Oyunluk',
    logo: '/images/logo-oyunluk.png',
    description: 'Geliştirme aşamasında. Daha fazla bilgi yakında paylaşılacak.',
    pageHref: '/oyunluk',
    storeUrl: null,
    badge: 'Geliştiriliyor',
    badgeClass: 'bg-violet-500/10 text-violet-400',
  },
];
---

<Layout
  title="Ana Sayfa"
  description="Company Software App — iOS, Android ve ötesi için dijital deneyimler."
>
  <Header />

  <main class="pt-16">

    <!-- Hero -->
    <section
      style="position: relative; min-height: calc(100vh - 64px); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 0 24px; overflow: hidden; background-image: radial-gradient(rgba(99,102,241,0.22) 1.5px, transparent 1.5px); background-size: 28px 28px;"
    >
      <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none;" aria-hidden="true">
        <div style="width: 640px; height: 640px; background: radial-gradient(circle, rgba(99,102,241,0.28) 0%, rgba(34,211,238,0.08) 50%, transparent 70%); border-radius: 50%;"></div>
      </div>

      <div style="position: relative; z-index: 10; max-width: 768px;">
        <p class="text-xs font-medium text-slate-500 tracking-[0.2em] uppercase mb-5">
          Company Software App
        </p>
        <h1 class="font-heading text-5xl md:text-7xl font-bold leading-tight mb-5">
          <span style="background: linear-gradient(90deg, #818cf8, #22d3ee, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            Harika uygulamalar
          </span>
          <br />
          <span class="text-white">hayatı kolaylaştırır.</span>
        </h1>
        <p class="text-slate-400 text-lg md:text-xl max-w-xl mx-auto mb-8 leading-relaxed">
          iOS, Android ve ötesi için yalın, güçlü dijital deneyimler tasarlıyoruz.
        </p>
        <a
          href="#uygulamalar"
          class="inline-flex items-center gap-2 text-white font-medium px-7 py-3.5 rounded-xl transition-colors duration-200"
          style="background-color: #6366F1;"
        >
          Uygulamalarımız
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </section>

    <!-- Uygulamalar -->
    <section id="uygulamalar" class="max-w-6xl mx-auto px-6 py-16">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">Uygulama ve Oyunlar</h2>
        <p class="text-slate-400 text-lg">Her biri farklı bir deneyim sunuyor.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {apps.map(app => (
          <a
            href={app.pageHref}
            class="app-card group flex flex-col gap-5 rounded-2xl p-7 border transition-all duration-300"
            style="background-color: #12121A; border-color: rgba(255,255,255,0.05);"
          >
            <img src={app.logo} alt={app.name} width="64" height="64" class="w-16 h-16 rounded-xl shrink-0 object-contain" />

            <div class="flex-1 flex flex-col gap-2">
              <div class="flex items-center gap-2.5">
                <h3 class="font-heading text-xl font-semibold text-white">{app.name}</h3>
                {app.badge && (
                  <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${app.badgeClass}`}>{app.badge}</span>
                )}
              </div>
              <p class="text-slate-400 text-sm leading-relaxed">{app.description}</p>
            </div>

            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-500 group-hover:text-white transition-colors">
                Daha fazla →
              </span>
              {app.storeUrl && (
                <span
                  class="text-sm font-medium px-4 py-1.5 rounded-lg text-indigo-400"
                  style="background-color: rgba(99,102,241,0.1);"
                >
                  App Store ↗
                </span>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .app-card:hover {
    border-color: rgba(99,102,241,0.35);
    box-shadow: 0 0 40px rgba(99,102,241,0.09);
  }
</style>
