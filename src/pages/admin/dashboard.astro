                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </button>
            <div class="search-input-container" id="searchInputContainer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <input type="text" id="searchInput" class="search-input" placeholder="Başlık veya açıklama ara..." autocomplete="off" />
              <button class="btn-search-clear" id="searchClear" title="Temizle">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>
            </div>
          </div>
          <button class="btn-new-task" id="openNewTaskModal">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Yeni Görev
          </button>
          <div class="view-toggle">
            <button class="view-btn active" data-view="pending">
              Aktif
              <span class="badge-count" id="badge-pending">0</span>
            </button>
            <button class="view-btn" data-view="completed">
              Tamamlanan
              <span class="badge-count" id="badge-completed">0</span>
            </button>
            <button class="view-btn" data-view="trash">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path></svg>
              Çöp Kutusu
              <span class="badge-count" id="badge-trash">0</span>
            </button>
          </div>
        </div>
      </header>

      <!-- Project Filter -->
      <div class="project-filter">
        <button class="project-filter-item active" data-filter-project="all">
          <div class="filter-icon-all">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
          </div>
          <span>Tümü</span>
        </button>
        {projects.map(project => (
          <button class="project-filter-item" data-filter-project={project.id}>
            <img src={project.logo} alt={project.name} class="filter-project-logo" width="20" height="20" />
            <span>{project.name}</span>
          </button>
        ))}
      </div>

      <!-- Tasks List -->
      <div class="tasks-container">

        <!-- Pending Tasks -->
        <div class="tasks-view active" data-view-content="pending">
          {pendingTasks.length === 0 ? (
            <div class="empty-state">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 11 12 14 22 4"></polyline>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
              </svg>
              <h3>Harika! Tüm görevler tamamlandı</h3>
              <p>Yeni görevler eklemek için bir projeye gidin.</p>
            </div>
          ) : (
            <div class="task-list">
              {pendingTasks.map(task => (
                <div class="task-card" data-project-id={task.projectId} data-task-id={task.id}>
                  <div class="task-checkbox-wrapper">
                    <input
                      type="checkbox"
                      class="task-checkbox"
                      id={`task-${task.id}`}
                      data-project-id={task.projectId}
                      data-task-id={task.id}
                    />
                    <label for={`task-${task.id}`} class="checkbox-label"></label>
                  </div>
                  <div class="task-card-body">
                    <p class="task-text">{task.title || task.text || 'Görev'}</p>
                    <div class="task-meta">
                      <a href={`/admin/projects/${task.projectId}`} class="task-project">
                        <img src={task.projectLogo} alt={task.projectName} width="14" height="14" />
                        <span>{task.projectName}</span>
                      </a>
                      <span class="task-date">
                        {new Date(task.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' })}
                      </span>
                    </div>
                  </div>
                  <div class="task-card-footer">
                    {(task.description || task.text) && (
                      <button
                        class="btn-dash-expand"
                        data-task-id={task.id}
                        title="Detayları Göster"
                      >
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                      </button>
                    )}
                    <button
                      class="btn-task-prompt"
                      data-task-id={task.id}
                      data-project-id={task.projectId}
                      data-task-title={task.title || task.text}
                      data-task-description={task.description || task.text}
                      data-project-name={task.projectName}
                      title="Claude Prompt Oluştur"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                      </svg>
                    </button>
                    <button
                      class="btn-dash-delete"
                      data-task-id={task.id}
                      data-project-id={task.projectId}
                      title="Görevi Sil"
                    >
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                        <path d="M10 11v6"></path><path d="M14 11v6"></path>
                        <path d="M9 6V4h6v2"></path>
                      </svg>
                    </button>
                  </div>
                  {(task.description || task.text) && (
                    <div class="task-detail-dash" data-detail-id={task.id} style="display:none;">
                      <p>{task.description || task.text}</p>
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Completed Tasks -->
        <div class="tasks-view" data-view-content="completed">
          {completedTasks.length === 0 ? (
            <div class="empty-state">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
              <h3>Henüz tamamlanmış görev yok</h3>
              <p>Görevleri tamamladıkça burada görünecekler.</p>
            </div>
          ) : (
            <div class="task-list">
              {completedTasks.map(task => (
                <div class="task-card completed" data-project-id={task.projectId} data-task-id={task.id}>
                  <div class="task-checkbox-wrapper">
                    <input
                      type="checkbox"
                      class="task-checkbox"
                      checked
                      id={`task-c-${task.id}`}
                      data-project-id={task.projectId}
                      data-task-id={task.id}
                    />
                    <label for={`task-c-${task.id}`} class="checkbox-label"></label>
                  </div>
                  <div class="task-card-body">
                    <p class="task-text">{task.title || task.text || 'Görev'}</p>
                    <div class="task-meta">
                      <a href={`/admin/projects/${task.projectId}`} class="task-project">
                        <img src={task.projectLogo} alt={task.projectName} width="14" height="14" />
                        <span>{task.projectName}</span>
                      </a>
                      <span class="task-date completed-date">
                        {new Date(task.completedAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' })}
                      </span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Trash View -->
        <div class="tasks-view" data-view-content="trash">
          <div class="trash-header">
            <p class="trash-info">Silinen görevler burada saklanır. Kalıcı olarak silinmezler.</p>
            <button class="btn-empty-trash" id="emptyTrashBtn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path></svg>
              Tümünü Sil
            </button>
          </div>
          <div class="task-list" id="trashList">
            <div class="empty-state">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path></svg>
              <h3>Çöp kutusu boş</h3>
              <p>Silinen görevler burada görünecek.</p>
            </div>
          </div>
        </div>

      </div>
    </main>

  </div>

  <!-- Yeni Görev Modal -->
  <div class="modal" id="newTaskModal">
    <div class="modal-overlay" id="newTaskOverlay"></div>
    <div class="modal-card" style="max-width:520px;">
      <div class="modal-header">
        <h3>Yeni Görev</h3>
        <button class="modal-close" id="closeNewTaskModal">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div style="padding: 24px 28px; display:flex; flex-direction:column; gap:16px;">
        <div class="nt-form-group">
          <label class="nt-label">Proje</label>
          <select id="ntProject" class="nt-select">
            {projects.map(p => <option value={p.id} data-logo={p.logo} data-name={p.name}>{p.name}</option>)}
          </select>
        </div>
        <div class="nt-form-group">
          <label class="nt-label">Görev Başlığı</label>
          <input type="text" id="ntTitle" class="nt-input" placeholder="Örn: StoreKit Abonelik Sistemi" />
        </div>
        <div class="nt-form-group">
          <label class="nt-label">Kısa Açıklama</label>
          <textarea id="ntDescription" class="nt-input" rows="3" placeholder="Ne yapılacak?"></textarea>
        </div>
        <div id="ntError" style="color:#ef4444; font-size:13px; display:none;">Lütfen tüm alanları doldurun.</div>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-nt-cancel" id="cancelNewTask">İptal</button>
        <button type="button" class="btn-nt-save" id="saveNewTask">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
          Kaydet
        </button>
      </div>
    </div>
  </div>

  <!-- Prompt Modal -->
  <div class="modal" id="promptModal">
    <div class="modal-overlay"></div>
    <div class="modal-card modal-large">
      <div class="modal-header">
        <h3>Claude Prompt</h3>
        <button class="modal-close" id="closePromptModal">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <div class="prompt-preview">
        <pre id="generatedPrompt"></pre>
      </div>
      <div class="modal-actions">
        <button class="btn-download" id="downloadPromptBtn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          .md İndir
        </button>
        <button class="btn-submit" id="copyPromptBtn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          Kopyala
        </button>
      </div>
    </div>
  </div>

</Layout>

<script define:vars={{ projects }}>
  if (sessionStorage.getItem('adminAuth') !== 'true') {
    window.location.href = '/admin';
  }

  // ─── Trash ──────────────────────────────────────────────
  function getTrash() { return JSON.parse(localStorage.getItem('vibeco_trash') || '[]'); }
  function saveTrash(arr) { localStorage.setItem('vibeco_trash', JSON.stringify(arr)); }

  // ─── Load tasks from localStorage ───────────────────────
  let allTasks = [];

  projects.forEach(project => {
    const storageKey = `vibeco_tasks_${project.id}`;
    const localTasks = JSON.parse(localStorage.getItem(storageKey) || '[]');

    // Merge local tasks with server tasks
    const taskMap = new Map();

    // Add server tasks
    if (project.tasks) {
      project.tasks.forEach(task => {
        taskMap.set(task.id, {
          ...task,
          projectId: project.id,
          projectName: project.name,
          projectLogo: project.logo,
          projectStatus: project.status
        });
      });
    }

    // Override with local tasks (they are more recent)
    localTasks.forEach(task => {
      taskMap.set(task.id, {
        ...task,
        projectId: project.id,
        projectName: project.name,
        projectLogo: project.logo,
        projectStatus: project.status
      });
    });

    allTasks.push(...Array.from(taskMap.values()));
  });

  // Sort tasks
  allTasks.sort((a, b) => {
    if (a.completed === b.completed) {
      const dateA = a.completed ? new Date(a.completedAt) : new Date(a.createdAt);
      const dateB = b.completed ? new Date(b.completedAt) : new Date(b.createdAt);
      return dateB.getTime() - dateA.getTime();
    }
    return a.completed ? 1 : -1;
  });

  let pendingTasks = allTasks.filter(t => !t.completed);
  let completedTasks = allTasks.filter(t => t.completed);

  renderDashboardTasks();
  renderTrash();

  function renderDashboardTasks() {
    const taskCountEl = document.getElementById('taskCount');
    if (taskCountEl) taskCountEl.textContent = pendingTasks.length;
    const bp = document.getElementById('badge-pending');
    const bc = document.getElementById('badge-completed');
    if (bp) bp.textContent = pendingTasks.length;
    if (bc) bc.textContent = completedTasks.length;

    // ─── Pending ─────────────────────────────────────────
    const pendingView = document.querySelector('[data-view-content="pending"]');
    if (pendingView) {
      if (pendingTasks.length === 0) {
        pendingView.innerHTML = `<div class="empty-state"><svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg><h3>Aktif görev yok</h3><p>Yeni görev eklemek için "Yeni Görev" butonunu kullanın.</p></div>`;
      } else {
        pendingView.innerHTML = `<div class="task-list">${pendingTasks.map(task => `
          <div class="task-card" data-project-id="${task.projectId}" data-task-id="${task.id}">
            <div class="task-checkbox-wrapper">
              <input type="checkbox" class="task-checkbox" id="dash-t-${task.id}" data-project-id="${task.projectId}" data-task-id="${task.id}" />
              <label for="dash-t-${task.id}" class="checkbox-label"></label>
            </div>
            <div class="task-card-body">
              <p class="task-text">${task.title || task.text || 'Görev'}</p>
              <div class="task-meta">
                <a href="/admin/projects/${task.projectId}" class="task-project">
                  <img src="${task.projectLogo}" alt="${task.projectName}" width="14" height="14" />
                  <span>${task.projectName}</span>
                </a>
                <span class="task-date">${new Date(task.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' })}</span>
              </div>
            </div>
            <div class="task-card-footer">
              ${(task.description || task.text) ? `<button class="btn-dash-expand" data-task-id="${task.id}" title="Detayları Göster"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></button>` : ''}
              <button class="btn-task-prompt" data-task-id="${task.id}" data-task-title="${task.title}" data-task-description="${task.description || ''}" data-project-name="${task.projectName}" data-project-id="${task.projectId}" title="Claude Prompt Oluştur"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></button>
              <button class="btn-dash-delete" data-task-id="${task.id}" data-project-id="${task.projectId}" title="Görevi Sil"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path><path d="M9 6V4h6v2"></path></svg></button>
            </div>
            ${(task.description || task.text) ? `<div class="task-detail-dash" data-detail-id="${task.id}" style="display:none;"><p>${task.description || task.text}</p></div>` : ''}
          </div>`).join('')}</div>`;
        attachCheckboxListeners();
        attachPromptButtonListeners();
      }
    }

    // ─── Completed ───────────────────────────────────────
    const completedView = document.querySelector('[data-view-content="completed"]');
    if (completedView) {
      if (completedTasks.length === 0) {
        completedView.innerHTML = `<div class="empty-state"><svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg><h3>Henüz tamamlanmış görev yok</h3><p>Görevleri tamamladıkça burada görünecekler.</p></div>`;
      } else {
        completedView.innerHTML = `<div class="task-list">${completedTasks.map(task => `
          <div class="task-card completed" data-project-id="${task.projectId}" data-task-id="${task.id}">
            <div class="task-checkbox-wrapper">
              <input type="checkbox" class="task-checkbox" checked id="dash-tc-${task.id}" data-project-id="${task.projectId}" data-task-id="${task.id}" />
              <label for="dash-tc-${task.id}" class="checkbox-label"></label>
            </div>
            <div class="task-card-body">
              <p class="task-text">${task.title || task.text || 'Görev'}</p>
              <div class="task-meta">
                <a href="/admin/projects/${task.projectId}" class="task-project">
                  <img src="${task.projectLogo}" alt="${task.projectName}" width="14" height="14" />
                  <span>${task.projectName}</span>
                </a>
                <span class="task-date completed-date">${new Date(task.completedAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' })}</span>
              </div>
            </div>
            <div class="task-card-footer">
              <button class="btn-dash-delete" data-task-id="${task.id}" data-project-id="${task.projectId}" title="Görevi Sil"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path><path d="M10 11v6"></path><path d="M14 11v6"></path><path d="M9 6V4h6v2"></path></svg></button>
            </div>
          </div>`).join('')}</div>`;
        attachCheckboxListeners();
      }
    }

    // ─── Sidebar proje sayıları (localStorage'dan) ───────
    projects.forEach(project => {
      const projectTasks = allTasks.filter(t => t.projectId === project.id && !t.completed);
      const countEl = document.querySelector(`.project-item[href="/admin/projects/${project.id}"] .project-task-count`);
      if (countEl) countEl.textContent = projectTasks.length;
    });
  }

  function attachCheckboxListeners() {
    document.querySelectorAll('.task-checkbox').forEach(checkbox => {
      checkbox.addEventListener('change', (e) => {
        const projectId = checkbox.dataset.projectId;
        const taskId = checkbox.dataset.taskId;
        const isChecked = checkbox.checked;
        const today = new Date().toISOString().split('T')[0];

        // Find task
        const task = allTasks.find(t => t.id === taskId && t.projectId === projectId);
        if (task) {
          task.completed = isChecked;
          task.completedAt = isChecked ? today : null;

          // Update localStorage for this project
          const storageKey = `vibeco_tasks_${projectId}`;
          const projectTasks = allTasks.filter(t => t.projectId === projectId);
          localStorage.setItem(storageKey, JSON.stringify(projectTasks));

          pendingTasks = allTasks.filter(t => !t.completed);
          completedTasks = allTasks.filter(t => t.completed);
          renderDashboardTasks();
        }
      });
    });
  }

  // Prompt Modal
  const promptModal = document.getElementById('promptModal');
  const closePromptModal = document.getElementById('closePromptModal');
  const generatedPrompt = document.getElementById('generatedPrompt');
  const copyPromptBtn = document.getElementById('copyPromptBtn');
  const downloadPromptBtn = document.getElementById('downloadPromptBtn');
  let currentPromptText = '';
  const promptCache = {};

  async function openPromptModal(title, description, projectName, projectId, taskId) {
    currentPromptText = '';
    generatedPrompt.textContent = '';
    promptModal.classList.add('active');
    document.body.style.overflow = 'hidden';

    // Önbellekte varsa direkt göster
    const cacheKey = taskId ? `${projectId}_${taskId}` : null;
    if (cacheKey && promptCache[cacheKey]) {
      currentPromptText = promptCache[cacheKey];
      generatedPrompt.textContent = currentPromptText;
      copyPromptBtn.disabled = false;
      return;
    }

    generatedPrompt.innerHTML = '<span class="prompt-loading">Claude prompt hazırlıyor<span class="dots"><span>.</span><span>.</span><span>.</span></span></span>';
    copyPromptBtn.disabled = true;

    const project = projects.find(p => p.id === projectId);
    const platform = project?.platform || 'Mobil/Web';

    try {
      const res = await fetch('/api/generate-prompt', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, description, projectName, platform })
      });
      const data = await res.json();
      currentPromptText = data.prompt || data.error || 'Prompt oluşturulamadı.';
      if (cacheKey) promptCache[cacheKey] = currentPromptText;
      generatedPrompt.innerHTML = '';
      generatedPrompt.textContent = currentPromptText;
    } catch {
      currentPromptText = 'Bağlantı hatası. Sunucunun çalıştığından emin olun.';
      generatedPrompt.innerHTML = '';
      generatedPrompt.textContent = currentPromptText;
    }
    copyPromptBtn.disabled = false;
  }

  function closePromptModalFn() {
    promptModal.classList.remove('active');
    document.body.style.overflow = '';
  }

  closePromptModal?.addEventListener('click', closePromptModalFn);
  promptModal?.querySelector('.modal-overlay')?.addEventListener('click', closePromptModalFn);

  copyPromptBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText(currentPromptText);
    copyPromptBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Kopyalandı!';
    setTimeout(() => {
      copyPromptBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg> Kopyala';
    }, 2000);
  });

  downloadPromptBtn?.addEventListener('click', () => {
    const blob = new Blob([currentPromptText], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `task-prompt-${Date.now()}.md`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // Attach prompt button listeners
  function attachPromptButtonListeners() {
    document.querySelectorAll('.btn-task-prompt').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const title = btn.dataset.taskTitle;
        const description = btn.dataset.taskDescription;
        const projectName = btn.dataset.projectName;
        const projectId = btn.dataset.projectId;
        const taskId = btn.dataset.taskId;
        openPromptModal(title, description, projectName, projectId, taskId);
      });
    });
  }

  // Expand — event delegation (re-render'dan etkilenmez)
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.btn-dash-expand');
    if (!btn) return;
    e.stopPropagation();
    const taskId = btn.dataset.taskId;
    const detail = document.querySelector(`.task-detail-dash[data-detail-id="${taskId}"]`);
    if (!detail) return;
    const isOpen = detail.style.display === 'block';
    detail.style.display = isOpen ? 'none' : 'block';
    btn.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
  });

  // ─── Delete → Trash ─────────────────────────────────────
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.btn-dash-delete');
    if (!btn) return;
    e.stopPropagation();
    const taskId = btn.dataset.taskId;
    const projectId = btn.dataset.projectId;
    const task = allTasks.find(t => t.id === taskId && t.projectId === projectId);
    if (!task) return;
    if (!confirm(`"${task.title || task.text}" çöp kutusuna taşınsın mı?`)) return;

    // Move to trash
    const trash = getTrash();
    trash.push({ ...task, deletedAt: new Date().toISOString() });
    saveTrash(trash);

    // Remove from allTasks
    const idx = allTasks.findIndex(t => t.id === taskId && t.projectId === projectId);
    if (idx !== -1) allTasks.splice(idx, 1);

    // Update project localStorage
    const storageKey = `vibeco_tasks_${projectId}`;
    const projectTasks = allTasks.filter(t => t.projectId === projectId)
      .map(({ projectId: _p, projectName: _n, projectLogo: _l, projectStatus: _s, ...rest }) => rest);
    localStorage.setItem(storageKey, JSON.stringify(projectTasks));

    pendingTasks = allTasks.filter(t => !t.completed);
    completedTasks = allTasks.filter(t => t.completed);
    renderDashboardTasks();
    renderTrash();
  });

  // ─── Trash render ────────────────────────────────────────
  function renderTrash() {
    const trash = getTrash();
    const bt = document.getElementById('badge-trash');
    if (bt) bt.textContent = trash.length;
    const container = document.getElementById('trashList');
    if (!container) return;
    if (trash.length === 0) {
      container.innerHTML = `<div class="empty-state"><svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path></svg><h3>Çöp kutusu boş</h3><p>Silinen görevler burada görünecek.</p></div>`;
      return;
    }
    container.innerHTML = trash.map((task, idx) => `
      <div class="task-card trash-card">
        <div class="task-card-body">
          <p class="task-text" style="color:#6b7280;">${task.title || task.text || 'Görev'}</p>
          <div class="task-meta">
            <span class="task-project" style="color:#9ca3af;">
              <img src="${task.projectLogo || ''}" width="14" height="14" style="border-radius:3px;" />
              ${task.projectName || ''}
            </span>
            <span class="task-date">Silindi: ${new Date(task.deletedAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short' })}</span>
          </div>
        </div>
        <div class="task-card-footer">
          <button class="btn-trash-restore" data-trash-idx="${idx}" title="Geri Yükle">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
            Geri Yükle
          </button>
          <button class="btn-trash-perm-delete" data-trash-idx="${idx}" title="Kalıcı Sil">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path></svg>
            Sil
          </button>
        </div>
      </div>
    `).join('');
  }

  // Trash actions — event delegation
  document.addEventListener('click', (e) => {
    // Restore
    const restoreBtn = e.target.closest('.btn-trash-restore');
    if (restoreBtn) {
      const idx = parseInt(restoreBtn.dataset.trashIdx);
      const trash = getTrash();
      const task = trash[idx];
      if (!task) return;
      // Restore to project localStorage
      const { deletedAt, ...restoredTask } = task;
      const storageKey = `vibeco_tasks_${task.projectId}`;
      const existing = JSON.parse(localStorage.getItem(storageKey) || '[]');
      existing.push({ id: restoredTask.id, title: restoredTask.title, description: restoredTask.description, completed: restoredTask.completed, createdAt: restoredTask.createdAt, completedAt: restoredTask.completedAt });
      localStorage.setItem(storageKey, JSON.stringify(existing));
      // Remove from trash
      trash.splice(idx, 1);
      saveTrash(trash);
      // Add back to allTasks
      allTasks.push({ ...restoredTask });
      pendingTasks = allTasks.filter(t => !t.completed);
      completedTasks = allTasks.filter(t => t.completed);
      renderDashboardTasks();
      renderTrash();
      return;
    }
    // Permanent delete
    const permBtn = e.target.closest('.btn-trash-perm-delete');
    if (permBtn) {
      if (!confirm('Bu görev kalıcı olarak silinecek. Emin misin?')) return;
      const idx = parseInt(permBtn.dataset.trashIdx);
      const trash = getTrash();
      trash.splice(idx, 1);
      saveTrash(trash);
      renderTrash();
    }
  });

  // Empty all trash
  document.getElementById('emptyTrashBtn')?.addEventListener('click', () => {
    if (!confirm('Çöp kutusundaki tüm görevler kalıcı olarak silinecek. Emin misin?')) return;
    saveTrash([]);
    renderTrash();
  });

  // Clear localStorage (reset all task data)
  document.getElementById('clearStorageBtn')?.addEventListener('click', () => {
    if (!confirm('Tüm görev verileri (localStorage) sıfırlanacak. Bu işlem geri alınamaz. Devam edilsin mi?')) return;
    projects.forEach(p => localStorage.removeItem(`vibeco_tasks_${p.id}`));
    localStorage.removeItem('vibeco_trash');
    allTasks = [];
    pendingTasks = [];
    completedTasks = [];
    renderDashboardTasks();
    renderTrash();
  });

  // ─── Yeni Görev Modal ────────────────────────────────────
  const newTaskModal = document.getElementById('newTaskModal');
  document.getElementById('openNewTaskModal')?.addEventListener('click', () => {
    newTaskModal?.classList.add('active');
    document.body.style.overflow = 'hidden';
  });
  function closeNewTaskModal() {
    newTaskModal?.classList.remove('active');
    document.body.style.overflow = '';
    (document.getElementById('ntTitle')).value = '';
    (document.getElementById('ntDescription')).value = '';
    const err = document.getElementById('ntError');
    if (err) err.style.display = 'none';
  }
  document.getElementById('closeNewTaskModal')?.addEventListener('click', closeNewTaskModal);
  document.getElementById('cancelNewTask')?.addEventListener('click', closeNewTaskModal);
  document.getElementById('newTaskOverlay')?.addEventListener('click', closeNewTaskModal);

  document.getElementById('saveNewTask')?.addEventListener('click', () => {
    const projectId = (document.getElementById('ntProject')).value;
    const title = (document.getElementById('ntTitle')).value.trim();
    const description = (document.getElementById('ntDescription')).value.trim();
    const err = document.getElementById('ntError');
    if (!title || !description) {
      if (err) err.style.display = 'block';
      return;
    }
    if (err) err.style.display = 'none';
    const project = projects.find(p => p.id === projectId);
    if (!project) return;
    const today = new Date().toISOString().split('T')[0];
    const newTask = { id: Date.now().toString(), title, description, completed: false, createdAt: today, completedAt: null };
    // Save to project localStorage
    const storageKey = `vibeco_tasks_${projectId}`;
    const existing = JSON.parse(localStorage.getItem(storageKey) || '[]');
    existing.push(newTask);
    localStorage.setItem(storageKey, JSON.stringify(existing));
    // Add to allTasks
    allTasks.push({ ...newTask, projectId: project.id, projectName: project.name, projectLogo: project.logo, projectStatus: project.status });
    pendingTasks = allTasks.filter(t => !t.completed);
    completedTasks = allTasks.filter(t => t.completed);
    renderDashboardTasks();
    closeNewTaskModal();
  });

  // Initial attach
  attachPromptButtonListeners();

  // ─── Arama ───────────────────────────────────────────────
  const searchToggle = document.getElementById('searchToggle');
  const searchInputContainer = document.getElementById('searchInputContainer');
  const searchInput = document.getElementById('searchInput');
  const searchClear = document.getElementById('searchClear');
  let searchOpen = false;
  let searchQuery = '';

  searchToggle?.addEventListener('click', () => {
    searchOpen = !searchOpen;
    searchInputContainer.classList.toggle('open', searchOpen);
    if (searchOpen) {
      searchInput.focus();
    } else {
      searchInput.value = '';
      searchQuery = '';
      applySearch();
    }
  });

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    applySearch();
  });

  searchClear?.addEventListener('click', () => {
    searchInput.value = '';
    searchQuery = '';
    applySearch();
    searchInput.focus();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && searchOpen) {
      searchOpen = false;
      searchInputContainer.classList.remove('open');
      searchInput.value = '';
      searchQuery = '';
      applySearch();
    }
  });

  function applySearch() {
    const cards = document.querySelectorAll('[data-view-content="pending"] .task-card, [data-view-content="completed"] .task-card');
    let visibleCount = 0;
    cards.forEach(card => {
      const titleEl = card.querySelector('.task-text');
      const detailEl = card.querySelector('.task-detail-dash p');
      const title = (titleEl?.textContent || '').toLowerCase();
      const desc = (detailEl?.textContent || '').toLowerCase();
      const match = !searchQuery || title.includes(searchQuery) || desc.includes(searchQuery);
      card.style.display = match ? 'flex' : 'none';
      if (match && card.closest('[data-view-content="pending"]')) visibleCount++;
    });
    const taskCountEl = document.getElementById('taskCount');
    if (taskCountEl) taskCountEl.textContent = searchQuery ? visibleCount : pendingTasks.length;
    // Show/hide no-results message
    const pendingView = document.querySelector('[data-view-content="pending"]');
    if (pendingView && searchQuery) {
      let noRes = pendingView.querySelector('.search-no-result');
      const anyVisible = Array.from(pendingView.querySelectorAll('.task-card')).some(c => c.style.display !== 'none');
      if (!anyVisible) {
        if (!noRes) {
          noRes = document.createElement('div');
          noRes.className = 'search-no-result';
          noRes.innerHTML = `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg><p>"${searchInput.value}" için sonuç bulunamadı</p>`;
          pendingView.appendChild(noRes);
        } else {
          noRes.querySelector('p').textContent = `"${searchInput.value}" için sonuç bulunamadı`;
          noRes.style.display = 'flex';
        }
      } else if (noRes) {
        noRes.style.display = 'none';
      }
    } else {
      document.querySelector('.search-no-result')?.remove();
    }
  }

  // Logout
  document.getElementById('logoutBtn')?.addEventListener('click', () => {
    sessionStorage.removeItem('adminAuth');
    sessionStorage.removeItem('adminUser');
    window.location.href = '/admin';
  });

  // ─── Mobile Sidebar ─────────────────────────────────────
  const sidebar = document.getElementById('sidebar');
  const sidebarOverlay = document.getElementById('sidebarOverlay');
  const btnHamburger = document.getElementById('btnHamburger');
  const btnSidebarClose = document.getElementById('btnSidebarClose');

  function openMobileSidebar() {
    sidebar?.classList.add('mobile-open');
    sidebarOverlay?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeMobileSidebar() {
    sidebar?.classList.remove('mobile-open');
    sidebarOverlay?.classList.remove('active');
    document.body.style.overflow = '';
  }

  btnHamburger?.addEventListener('click', openMobileSidebar);
  btnSidebarClose?.addEventListener('click', closeMobileSidebar);
  sidebarOverlay?.addEventListener('click', closeMobileSidebar);

  // Mobile "Yeni Görev" shortcut — same as desktop button
  document.getElementById('btnMobileNewTask')?.addEventListener('click', () => {
    document.getElementById('openNewTaskModal')?.click();
  });

  // View toggle
  const viewBtns = document.querySelectorAll('.view-btn');
  const viewContents = document.querySelectorAll('.tasks-view');

  viewBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const view = btn.dataset.view;

      viewBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      viewContents.forEach(content => {
        if (content.dataset.viewContent === view) {
          content.classList.add('active');
        } else {
          content.classList.remove('active');
        }
      });
    });
  });

  // Project filter (new horizontal filter)
  const projectFilterItems = document.querySelectorAll('.project-filter-item');
  const taskCards = document.querySelectorAll('.task-card');
  const taskCountElement = document.getElementById('taskCount');

  function updateTaskCount() {
    const visibleTasks = Array.from(taskCards).filter(card =>
      card.style.display !== 'none' && card.closest('[data-view-content="pending"]')
    );
    taskCountElement.textContent = visibleTasks.length;
  }

  projectFilterItems.forEach(item => {
    item.addEventListener('click', () => {
      const filterProject = item.dataset.filterProject;

      // Update active state
      projectFilterItems.forEach(i => i.classList.remove('active'));
      item.classList.add('active');

      // Filter tasks
      if (filterProject === 'all') {
        taskCards.forEach(card => {
          card.style.display = 'flex';
        });
      } else {
        taskCards.forEach(card => {
          if (card.dataset.projectId === filterProject) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });
      }

      updateTaskCount();
    });
  });

  // Checkbox handling (placeholder - needs API)
  document.querySelectorAll('.task-checkbox').forEach(checkbox => {
    checkbox.addEventListener('change', (e) => {
      alert('Görev güncelleme özelliği API endpoint ile birlikte eklenecek.');
      e.target.checked = !e.target.checked; // Revert
    });
  });
</script>

