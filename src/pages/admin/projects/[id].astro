---
import Layout from '../../../layouts/Layout.astro';
import { readFile, readdir } from 'fs/promises';
import { join } from 'path';

export async function getStaticPaths() {
  const projectsDir = join(process.cwd(), 'data', 'admin', 'projects');
  let paths = [];

  try {
    const files = await readdir(projectsDir);
    const jsonFiles = files.filter(f => f.endsWith('.json'));

    paths = jsonFiles.map(file => ({
      params: { id: file.replace('.json', '') }
    }));
  } catch (error) {
    console.error('Error loading projects for static paths:', error);
  }

  return paths;
}

const { id } = Astro.params;

// Load project data
const projectFile = join(process.cwd(), 'data', 'admin', 'projects', `${id}.json`);
let project = null;
let prompts = [];
let tasks = [];

try {
  const content = await readFile(projectFile, 'utf-8');
  project = JSON.parse(content);
  prompts = project.prompts || [];
  tasks = project.tasks || [];
} catch (error) {
  return Astro.redirect('/admin/dashboard');
}

if (!project) {
  return Astro.redirect('/admin/dashboard');
}

// Load markdown notes
const notesDir = join(process.cwd(), 'data', 'admin', 'projects', id, 'notes');
let notes = [];
try {
  const noteFiles = await readdir(notesDir);
  notes = noteFiles.filter(f => f.endsWith('.md'));
} catch (error) {
  // Notes directory doesn't exist yet
}

// Sort tasks
const pendingTasks = tasks.filter(t => !t.completed).sort((a, b) =>
  new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
);
const completedTasks = tasks.filter(t => t.completed).sort((a, b) =>
  new Date(b.completedAt).getTime() - new Date(a.completedAt).getTime()
);
---

<Layout title={`${project.name} - Admin`} description={project.description}>
  <div class="project-detail">

    <!-- Header -->
    <header class="project-header">
      <div class="header-content">
        <a href="/admin/dashboard" class="btn-back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Dashboard
        </a>
        <div class="header-project">
          <img src={project.logo} alt={project.name} class="header-logo" />
          <div>
            <h1>{project.name}</h1>
            <p class="header-subtitle">{project.platform}</p>
          </div>
        </div>
        <span class={`header-status status-${project.status.toLowerCase().replace(/ı/g, 'i')}`}>
          {project.status}
        </span>
      </div>
    </header>

    <!-- Main Content -->
    <main class="project-main">
      <div class="project-container">

        <!-- Task/Journal Section -->
        <section class="section">
          <div class="section-header">
            <div class="section-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 20h9"></path>
                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
              </svg>
            </div>
            <div>
              <h2>Proje Günlüğü & Görevler</h2>
              <p class="section-desc">{pendingTasks.length} aktif görev • {completedTasks.length} tamamlandı</p>
            </div>
            <button class="btn-add" id="addTaskBtn" onclick="window.openTaskModal()">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
              Yeni Görev
            </button>
          </div>

          <div class="task-tabs">
            <button class="task-tab active" data-tab="pending">
              Aktif
              <span class="tab-badge">{pendingTasks.length}</span>
            </button>
            <button class="task-tab" data-tab="completed">
              Tamamlanan
              <span class="tab-badge">{completedTasks.length}</span>
            </button>
          </div>

          <!-- Pending Tasks -->
          <div class="task-tab-content active" data-tab-content="pending">
            {pendingTasks.length === 0 ? (
              <div class="empty-state-inline">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 11 12 14 22 4"></polyline>
                  <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                </svg>
                <p>Tüm görevler tamamlandı!</p>
              </div>
            ) : (
              <div class="task-list-modern">
                {pendingTasks.map((task, index) => (
                  <div class="task-item-modern">
                    <div class="task-check-wrapper">
                      <input
                        type="checkbox"
                        class="task-check"
                        id={`t-${task.id}`}
                        data-task-id={task.id}
                      />
                      <label for={`t-${task.id}`} class="task-check-label"></label>
                    </div>
                    <div class="task-item-content">
                      <p class="task-item-title">{task.title}</p>
                      <span class="task-item-date">
                        {new Date(task.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
                      </span>
                    </div>
                    <div class="task-actions">
                      <button class="btn-task-action btn-expand" data-task-id={task.id} title="Detayları Göster">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                      </button>
                      <button class="btn-task-action btn-prompt" data-task-id={task.id} data-task-title={task.title} data-task-description={task.description} title="Claude Prompt Oluştur">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                        </svg>
                      </button>
                    </div>
                    <div class="task-detail" data-task-detail={task.id} style="display: none;">
                      <div class="task-description">
                        <p>{task.description}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>

          <!-- Completed Tasks -->
          <div class="task-tab-content" data-tab-content="completed">
            {completedTasks.length === 0 ? (
              <div class="empty-state-inline">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="8" x2="12" y2="12"></line>
                  <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <p>Henüz tamamlanmış görev yok</p>
              </div>
            ) : (
              <div class="task-list-modern">
                {completedTasks.map((task, index) => (
                  <div class="task-item-modern completed">
                    <div class="task-check-wrapper">
                      <input
                        type="checkbox"
                        class="task-check"
                        checked
                        id={`tc-${task.id}`}
                        data-task-id={task.id}
                      />
                      <label for={`tc-${task.id}`} class="task-check-label"></label>
                    </div>
                    <div class="task-item-content">
                      <p class="task-item-title">{task.title}</p>
                      <span class="task-item-date completed-badge">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        {new Date(task.completedAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </section>

      </div>
    </main>

    <!-- Prompt Modal -->
    <div class="modal" id="promptModal">
      <div class="modal-overlay"></div>
      <div class="modal-content modal-large">
        <div class="modal-header">
          <h3>Claude Prompt</h3>
          <button class="modal-close" id="closePromptModal">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <div class="modal-body">
          <div class="prompt-preview">
            <pre id="generatedPrompt"></pre>
          </div>
          <div class="modal-actions">
            <button type="button" class="btn-download" id="downloadPromptBtn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              .md İndir
            </button>
            <button type="button" class="btn-submit" id="copyPromptBtn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              Kopyala
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Add Task Modal -->
    <div class="modal" id="addTaskModal">
      <div class="modal-overlay"></div>
      <div class="modal-content">
        <div class="modal-header">
          <h3>Yeni Görev Ekle</h3>
          <button class="modal-close" id="closeTaskModal">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <div class="modal-body">
          <form id="addTaskForm">
            <div class="form-group">
              <label for="taskTitle">Görev Başlığı</label>
              <input
                type="text"
                id="taskTitle"
                name="taskTitle"
                placeholder="Örn: StoreKit Abonelik Sistemi"
                required
              />
            </div>
            <div class="form-group">
              <label for="taskDescription">Kısa Açıklama</label>
              <textarea
                id="taskDescription"
                name="taskDescription"
                rows="4"
                placeholder="Ne yapılacak? Claude'un anlayacağı şekilde kısa ve öz yazın..."
                required
              ></textarea>
              <small class="form-hint">Bu açıklama Claude için prompt oluşturmada kullanılacak</small>
            </div>
            <div class="modal-actions">
              <button type="button" class="btn-cancel" id="cancelTaskBtn">İptal</button>
              <button type="submit" class="btn-submit">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                  <polyline points="17 21 17 13 7 13 7 21"></polyline>
                  <polyline points="7 3 7 8 15 8"></polyline>
                </svg>
                Kaydet
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

  </div>
</Layout>

<script define:vars={{ project, prompts, tasks }}>
  // Check authentication
  if (sessionStorage.getItem('adminAuth') !== 'true') {
    window.location.href = '/admin';
  }

  // Load from localStorage and merge
  const storageKey = `vibeco_tasks_${project.id}`;
  const localTasks = JSON.parse(localStorage.getItem(storageKey) || '[]');

  const taskMap = new Map();
  tasks.forEach(task => taskMap.set(task.id, task));
  localTasks.forEach(task => taskMap.set(task.id, task));

  let allTasks = Array.from(taskMap.values());

  // Re-render tasks
  function renderTasks() {
    const pendingTasksList = allTasks.filter(t => !t.completed).sort((a, b) =>
      new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
    );
    const completedTasksList = allTasks.filter(t => t.completed).sort((a, b) =>
      new Date(b.completedAt).getTime() - new Date(a.completedAt).getTime()
    );

    // Render pending tasks
    const pendingContainer = document.querySelector('[data-tab-content="pending"] .task-list-modern');
    if (pendingContainer) {
      if (pendingTasksList.length === 0) {
        pendingContainer.innerHTML = '<div class="empty-state-inline"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg><p>Tüm görevler tamamlandı!</p></div>';
      } else {
        pendingContainer.innerHTML = pendingTasksList.map(task => `
          <div class="task-item-modern">
            <div class="task-check-wrapper">
              <input type="checkbox" class="task-check" id="t-${task.id}" data-task-id="${task.id}" />
              <label for="t-${task.id}" class="task-check-label"></label>
            </div>
            <div class="task-item-content">
              <p class="task-item-title">${task.title}</p>
              <span class="task-item-date">${new Date(task.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </div>
            <div class="task-actions">
              <button class="btn-task-action btn-expand" data-task-id="${task.id}" title="Detayları Göster">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </button>
              <button class="btn-task-action btn-prompt" data-task-id="${task.id}" data-task-title="${task.title}" data-task-description="${task.description}" title="Claude Prompt Oluştur">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
              </button>
            </div>
            <div class="task-detail" data-task-detail="${task.id}" style="display: none;">
              <div class="task-description"><p>${task.description}</p></div>
            </div>
          </div>
        `).join('');
      }
    }

    // Render completed tasks
    const completedContainer = document.querySelector('[data-tab-content="completed"] .task-list-modern');
    if (completedContainer) {
      if (completedTasksList.length === 0) {
        completedContainer.innerHTML = '<div class="empty-state-inline"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg><p>Henüz tamamlanmış görev yok</p></div>';
      } else {
        completedContainer.innerHTML = completedTasksList.map(task => `
          <div class="task-item-modern completed">
            <div class="task-check-wrapper">
              <input type="checkbox" class="task-check" checked id="tc-${task.id}" data-task-id="${task.id}" />
              <label for="tc-${task.id}" class="task-check-label"></label>
            </div>
            <div class="task-item-content">
              <p class="task-item-title">${task.title}</p>
              <span class="task-item-date completed-badge">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                ${new Date(task.completedAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
            </div>
          </div>
        `).join('');
      }
    }

    // Re-attach event listeners
    attachTaskEventListeners();
  }

  // Initial render
  renderTasks();

  // Task tabs
  const taskTabs = document.querySelectorAll('.task-tab');
  const taskTabContents = document.querySelectorAll('.task-tab-content');

  taskTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetTab = tab.dataset.tab;

      taskTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      taskTabContents.forEach(content => {
        if (content.dataset.tabContent === targetTab) {
          content.classList.add('active');
        } else {
          content.classList.remove('active');
        }
      });
    });
  });

  // Copy to clipboard helper
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text);
  }

  // Modal functionality
  const addTaskModal = document.getElementById('addTaskModal');
  const addTaskBtn = document.getElementById('addTaskBtn');
  const closeTaskModal = document.getElementById('closeTaskModal');
  const cancelTaskBtn = document.getElementById('cancelTaskBtn');
  const addTaskForm = document.getElementById('addTaskForm');
  const taskModalOverlay = addTaskModal?.querySelector('.modal-overlay');

  function openModal() {
    console.log('Opening modal...', addTaskModal);
    if (addTaskModal) {
      addTaskModal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeModal() {
    if (addTaskModal) {
      addTaskModal.classList.remove('active');
      document.body.style.overflow = '';
      addTaskForm?.reset();
    }
  }

  // Make openModal global for onclick
  window.openTaskModal = openModal;

  if (addTaskBtn) {
    console.log('addTaskBtn found, attaching listener');
    addTaskBtn.addEventListener('click', openModal);
  } else {
    console.error('addTaskBtn not found!');
  }

  closeTaskModal?.addEventListener('click', closeModal);
  cancelTaskBtn?.addEventListener('click', closeModal);
  taskModalOverlay?.addEventListener('click', closeModal);

  // Handle form submission
  addTaskForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    const taskTitle = document.getElementById('taskTitle').value;
    const taskDescription = document.getElementById('taskDescription').value;
    const today = new Date().toISOString().split('T')[0];

    if (taskTitle.trim() && taskDescription.trim()) {
      const newTask = {
        id: Date.now().toString(),
        title: taskTitle,
        description: taskDescription,
        completed: false,
        createdAt: today,
        completedAt: null
      };

      // Save to localStorage
      const storageKey = `vibeco_tasks_${project.id}`;
      const existingTasks = JSON.parse(localStorage.getItem(storageKey) || '[]');
      existingTasks.push(newTask);
      localStorage.setItem(storageKey, JSON.stringify(existingTasks));

      // Add to allTasks array
      allTasks.push(newTask);

      // Re-render tasks
      renderTasks();

      // Close modal and reset form
      closeModal();
    }
  });


  // Prompt Modal
  const promptModal = document.getElementById('promptModal');
  const closePromptModal = document.getElementById('closePromptModal');
  const generatedPrompt = document.getElementById('generatedPrompt');
  const copyPromptBtn = document.getElementById('copyPromptBtn');
  const downloadPromptBtn = document.getElementById('downloadPromptBtn');
  let currentPromptText = '';

  function openPromptModal(title, description) {
    const prompt = `# Task: ${title}

## Project Context
- **Project:** ${project.name}
- **Platform:** ${project.platform}
- **Status:** ${project.status}

## Task Description
${description}

## Requirements
Please implement this task for the ${project.name} project. Follow best practices and ensure the code is clean, maintainable, and well-documented.

## Additional Context
- Keep the implementation consistent with the existing codebase
- Consider edge cases and error handling
- Write clear commit messages when done

---
Generated by VibeCo - Project Management for Developers`;

    currentPromptText = prompt;
    generatedPrompt.textContent = prompt;
    promptModal.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closePromptModalFn() {
    promptModal.classList.remove('active');
    document.body.style.overflow = '';
  }

  closePromptModal?.addEventListener('click', closePromptModalFn);
  promptModal?.querySelector('.modal-overlay')?.addEventListener('click', closePromptModalFn);

  copyPromptBtn?.addEventListener('click', () => {
    copyToClipboard(currentPromptText);
    copyPromptBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Kopyalandı!';
    setTimeout(() => {
      copyPromptBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg> Kopyala';
    }, 2000);
  });

  downloadPromptBtn?.addEventListener('click', () => {
    const blob = new Blob([currentPromptText], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${project.id}-task-prompt-${Date.now()}.md`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // Attach event listeners to tasks
  function attachTaskEventListeners() {
    // Expand/Collapse task details
    document.querySelectorAll('.btn-expand').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const taskId = btn.dataset.taskId;
        const detail = document.querySelector(`[data-task-detail="${taskId}"]`);
        const isExpanded = detail.style.display === 'block';

        detail.style.display = isExpanded ? 'none' : 'block';
        btn.style.transform = isExpanded ? 'rotate(0deg)' : 'rotate(180deg)';
      });
    });

    // Generate Prompt
    document.querySelectorAll('.btn-prompt').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const title = btn.dataset.taskTitle;
        const description = btn.dataset.taskDescription;
        openPromptModal(title, description);
      });
    });

    // Checkbox handling
    document.querySelectorAll('.task-check').forEach(checkbox => {
      checkbox.addEventListener('change', (e) => {
        const today = new Date().toISOString().split('T')[0];
        const taskId = checkbox.dataset.taskId;
        const isChecked = checkbox.checked;

        // Find task and update
        const task = allTasks.find(t => t.id === taskId);
        if (task) {
          task.completed = isChecked;
          task.completedAt = isChecked ? today : null;

          // Save to localStorage
          const storageKey = `vibeco_tasks_${project.id}`;
          localStorage.setItem(storageKey, JSON.stringify(allTasks));

          // Re-render
          renderTasks();
        }
      });
    });
  }
</script>

<style>
  .project-detail {
    min-height: 100vh;
    background: #f8f9fa;
  }

  /* ─── Header ────────────────────────────────────── */
  .project-header {
    background: white;
    border-bottom: 1px solid #e5e7eb;
