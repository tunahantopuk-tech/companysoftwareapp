---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const accent = '#7B2FBE';
const lastUpdated = '14 Haziran 2026';

const sections = [
  {
    title: 'Kabul ve Kapsam',
    content: 'Oyunluk uygulamasını ("Uygulama") indirip kullanarak bu Kullanım Koşulları\'nı ve Gizlilik Politikası\'nı okuduğunuzu, anladığınızı ve kabul ettiğinizi beyan edersiniz. Bu koşulları kabul etmiyorsanız uygulamayı kullanmayınız. Uygulama Apple App Store aracılığıyla dağıtılmaktadır; Apple\'ın Son Kullanıcı Lisans Sözleşmesi (EULA) de uygulanır.',
    link: { text: 'Apple EULA ↗', href: 'https://www.apple.com/legal/internet-services/itunes/dev/stdeula/' },
  },
  {
    title: 'Hizmetin Açıklaması',
    content: 'Oyunluk, oyun kütüphanesi yönetimi, oyun keşfi, çok mağazalı fiyat takibi (Steam, Epic, GOG, Humble) ve yapay zeka destekli öneri gibi özellikler sunan ücretsiz bir iOS uygulamasıdır. Uygulama içinde isteğe bağlı Oyunluk+ aboneliği sunulmaktadır. Oyun verileri üçüncü taraf API\'ler aracılığıyla sunulmakta olup verilerinin doğruluğunu garanti etmiyoruz.',
  },
  {
    title: 'Hesap ve Kimlik Doğrulama',
    content: 'Uygulamayı kullanmak için Apple ID, Google hesabı veya misafir (anonim) girişiyle oturum açmanız gerekmektedir. Misafir girişinde verileriniz yalnızca cihazınızda saklanır ve hesap kurtarma mümkün değildir. Hesabınızın güvenliğinden siz sorumlusunuz.',
    email: 'support@oyunluk.net',
  },
  {
    title: 'Oyunluk+ Aboneliği',
    content: 'Oyunluk+, aylık veya yıllık olarak sunulan isteğe bağlı premium abonelik hizmetidir. Abonelikler, dönem sona ermeden en az 24 saat önce iptal edilmediği sürece otomatik olarak yenilenir. İptal için App Store > Hesap > Abonelikler menüsünü kullanın. İptal, mevcut ödeme döneminin sonunda geçerli olur; kalan süre için iade yapılmaz. İadeler Apple\'ın iade politikasına tabidir.',
    link: { text: 'Apple Destek — İade ↗', href: 'https://getsupport.apple.com' },
  },
  {
    title: 'Reklamlar ve ATT',
    content: 'Uygulama, ücretsiz kullanıcılara Google AdMob aracılığıyla reklam gösterir. Premium (Oyunluk+) üyelerine reklam gösterilmez. Apple\'ın App Tracking Transparency (ATT) çerçevesi kapsamında kişiselleştirilmiş reklam sunmak için cihazınızın reklam kimliğine (IDFA) erişim izni talep ederiz. İzni reddetmeniz uygulama deneyiminizi etkilemez.',
  },
  {
    title: 'Kullanım Kuralları',
    content: 'Uygulamayı yalnızca kişisel ve ticari olmayan amaçlarla, yürürlükteki yasalara uygun olarak kullanabilirsiniz. Yasak eylemler: uygulamayı ters mühendislik veya kopyalamak; güvenlik özelliklerini atlatmaya çalışmak; uygulamayı üçüncü kişilere satmak veya devretmek; yasadışı amaçlarla kullanmak; diğer kullanıcılara zarar verecek eylemler gerçekleştirmek.',
  },
  {
    title: 'Fikri Mülkiyet',
    content: 'Oyunluk adı, logosu, tasarımı ve arayüzü geliştiriciye ve/veya lisans verenlerine aittir. Oyun verileri RAWG Video Games Database\'e, oyun görselleri ve markaları ilgili hak sahiplerine aittir. Steam, Valve Corporation\'ın tescilli markasıdır. Bu uygulama söz konusu markalarla herhangi bir bağlantı veya ortaklık iddiasında bulunmamaktadır.',
  },
  {
    title: 'Sorumluluk Sınırlaması',
    content: 'Uygulama "olduğu gibi" (as-is) sunulmaktadır. Uygulamanın kesintisiz veya hatasız çalışacağını garanti etmiyoruz. Yürürlükteki yasaların izin verdiği ölçüde dolaylı veya arızi zararlardan sorumlu değiliz. Doğrudan zararlar için sorumluluğumuz, son 12 ayda ödenen toplam abonelik ücretiyle sınırlıdır.',
  },
  {
    title: 'Hizmet Değişiklikleri',
    content: 'Uygulamayı güncelleme, değiştirme veya sonlandırma hakkını önceden bildirimde bulunmaksızın saklı tutarız. Teknik arızalar, bakım dönemleri veya dış faktörlerden kaynaklanan kesintiler için sorumluluk kabul etmiyoruz.',
  },
  {
    title: 'Uygulanacak Hukuk',
    content: 'Bu koşullar Türkiye Cumhuriyeti hukukuna göre yorumlanır ve uygulanır. Uyuşmazlıklar öncelikle dostane yollarla çözülmeye çalışılacak; sonuç alınamazsa Türkiye mahkemelerinde görülecektir. AB veya ABD\'deki kullanıcılar için yerel tüketici koruma mevzuatından doğan haklar saklıdır.',
  },
  {
    title: 'Koşulların Değiştirilmesi',
    content: 'Bu koşulları zaman zaman güncelleyebiliriz. Önemli değişiklikler uygulama içi bildirim veya güncelleme notlarıyla duyurulacaktır. Değişiklikten sonra uygulamayı kullanmaya devam etmeniz, güncellenmiş koşulları kabul ettiğiniz anlamına gelir.',
  },
  {
    title: 'İletişim',
    content: 'Kullanım koşullarına ilişkin sorularınız için bizimle iletişime geçebilirsiniz:',
    email: 'support@oyunluk.net',
  },
];
---

<Layout
  title="Oyunluk — Kullanım Koşulları"
  description="Oyunluk uygulaması kullanım koşulları ve hizmet şartları."
  ogImage="/images/logo-oyunluk.png"
>
  <Header />

  <main class="doc-page">

    <section class="doc-hero">
      <div class="doc-hero-inner">
        <a href="/oyunluk" class="doc-app-link">
          <img src="/images/logo-oyunluk.png" alt="Oyunluk" class="doc-app-logo" />
          <span class="doc-app-name">Oyunluk</span>
        </a>
        <h1 class="doc-title">Kullanım Koşulları</h1>
        <p class="doc-date">Son güncelleme: <span style={`color:${accent};`}>{lastUpdated}</span></p>
        <p class="doc-intro">Oyunluk'u kullanmadan önce lütfen aşağıdaki koşulları okuyunuz.</p>
      </div>
    </section>

    <div class="doc-body">
      {sections.map((s, i) => (
        <div class="doc-section">
          <div class="doc-num-wrap" style={`background:${accent}18; border:1px solid ${accent}30;`}>
            <span class="doc-num" style={`color:${accent};`}>{i + 1}</span>
          </div>
          <div class="doc-content">
            <h2>{s.title}</h2>
            <p>{s.content}</p>
            {s.link && (
              <a href={s.link.href} target="_blank" rel="noopener noreferrer" class="doc-link" style={`color:${accent};`}>
                {s.link.text}
              </a>
            )}
            {s.email && (
              <a href={`mailto:${s.email}`} class="doc-link" style={`color:${accent};`}>
                {s.email}
              </a>
            )}
          </div>
        </div>
      ))}

      <div class="doc-footer-links">
        <a href="/oyunluk/privacy" style={`color:${accent};`}>Gizlilik Politikası →</a>
      </div>

      <div class="doc-back">
        <a href="/oyunluk">← Oyunluk'a Dön</a>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  .doc-page { padding-top: 48px; }

  .doc-hero {
    padding: 64px 24px 56px;
    text-align: center;
    background: var(--bg-section-alt);
    border-bottom: 1px solid var(--border-faint);
  }
  .doc-hero-inner {
    max-width: 640px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; gap: 14px;
  }
  .doc-app-link {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; margin-bottom: 4px;
  }
  .doc-app-logo { width: 44px; height: 44px; border-radius: 10px; }
  .doc-app-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem; font-weight: 600;
    color: var(--color-text);
  }
  .doc-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700; line-height: 1.2;
    color: var(--color-text);
  }
  .doc-date { font-size: 0.875rem; color: var(--color-subtle); }
  .doc-intro {
    font-size: 0.95rem; color: var(--color-muted);
    line-height: 1.7; max-width: 500px;
  }

  .doc-body {
    max-width: 720px; margin: 0 auto;
    padding: 48px 24px 80px;
  }
  .doc-section {
    display: flex; gap: 20px;
    padding: 32px 0;
    border-bottom: 1px solid var(--border-faint);
  }
  .doc-section:last-of-type { border-bottom: none; }

  .doc-num-wrap {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 2px;
  }
  .doc-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem; font-weight: 700;
  }
  .doc-content { flex: 1; }
  .doc-content h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.05rem; font-weight: 600;
    color: var(--color-text); margin-bottom: 10px;
  }
  .doc-content p {
    font-size: 0.9rem; color: var(--color-muted); line-height: 1.75;
  }
  .doc-link {
    display: inline-block; margin-top: 10px;
    font-size: 0.9rem; font-weight: 500;
    text-decoration: none; transition: opacity 0.15s ease;
  }
  .doc-link:hover { opacity: 0.7; }

  .doc-footer-links {
    margin-top: 48px; text-align: center;
    font-size: 0.875rem; font-weight: 500;
  }
  .doc-footer-links a { text-decoration: none; transition: opacity 0.15s; }
  .doc-footer-links a:hover { opacity: 0.7; }

  .doc-back { margin-top: 16px; text-align: center; }
  .doc-back a {
    font-size: 0.875rem; color: var(--color-subtle);
    text-decoration: none; transition: color 0.15s ease;
  }
  .doc-back a:hover { color: var(--color-muted); }
</style>
